<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="using:TOrbit.Designer.Controls"
             x:Class="TOrbit.Designer.Controls.ActionBar"
             x:DataType="controls:ActionBar"
             x:Name="Root">
  <Border Background="{DynamicResource TOrbitSurfaceElevatedBrush}"
          BorderBrush="{DynamicResource TOrbitBorderBrush}"
          BorderThickness="1"
          CornerRadius="{DynamicResource TOrbitRadiusLarge}"
          Padding="18,12">
    <StackPanel Spacing="10">

      <!-- Lead + Status row -->
      <Grid ColumnDefinitions="*,Auto" ColumnSpacing="16">
        <ContentPresenter Content="{Binding LeadContent, ElementName=Root}"
                          VerticalAlignment="Center" />
        <StackPanel Grid.Column="1"
                    Orientation="Horizontal"
                    Spacing="10"
                    VerticalAlignment="Center">
          <TextBlock Text="{Binding StatusText, ElementName=Root}"
                     Foreground="{DynamicResource TOrbitTextMutedBrush}"
                     FontSize="12"
                     VerticalAlignment="Center" />
          <ProgressBar Width="80"
                       Height="3"
                       IsIndeterminate="True"
                       IsVisible="{Binding IsBusy, ElementName=Root}"
                       Foreground="{DynamicResource TOrbitAccentBrush}"
                       CornerRadius="2" />
        </StackPanel>
      </Grid>

      <!-- Actions row -->
      <ContentPresenter Content="{Binding ActionsContent, ElementName=Root}" />

    </StackPanel>
  </Border>
</UserControl>
