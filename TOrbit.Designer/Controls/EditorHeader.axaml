<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="using:TOrbit.Designer.Controls"
             x:Class="TOrbit.Designer.Controls.EditorHeader"
             x:DataType="controls:EditorHeader"
             x:Name="Root">
  <Grid ColumnDefinitions="*,Auto"
        ColumnSpacing="12"
        MinHeight="36">
    <!-- Filename chip in monospace -->
    <Border Background="{DynamicResource TOrbitSurfaceElevatedBrush}"
            BorderBrush="{DynamicResource TOrbitBorderBrush}"
            BorderThickness="1"
            CornerRadius="{DynamicResource TOrbitRadiusSmall}"
            Padding="10,5"
            HorizontalAlignment="Left"
            VerticalAlignment="Center">
      <TextBlock Text="{Binding Title, ElementName=Root}"
                 FontFamily="{DynamicResource TOrbitMonoFontFamily}"
                 FontSize="12"
                 Foreground="{DynamicResource TOrbitAccentSubtleForegroundBrush}"
                 VerticalAlignment="Center" />
    </Border>
    <ContentPresenter Grid.Column="1"
                      Content="{Binding ActionContent, ElementName=Root}"
                      VerticalAlignment="Center" />
  </Grid>
</UserControl>
