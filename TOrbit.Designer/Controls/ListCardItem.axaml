<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="using:TOrbit.Designer.Controls"
             x:Class="TOrbit.Designer.Controls.ListCardItem"
             x:DataType="controls:ListCardItem"
             x:Name="Root">
  <Border Margin="0,0,0,6"
          Padding="14,10"
          CornerRadius="{DynamicResource TOrbitRadiusMedium}"
          Background="{DynamicResource TOrbitSurfaceElevatedBrush}"
          BorderBrush="{DynamicResource TOrbitBorderBrush}"
          BorderThickness="1">
    <StackPanel Spacing="3">
      <TextBlock Text="{Binding Title, ElementName=Root}"
                 FontSize="13"
                 FontWeight="SemiBold" />
      <TextBlock Classes="caption-muted"
                 Text="{Binding Subtitle, ElementName=Root}" />
      <TextBlock Classes="caption-muted"
                 Text="{Binding Meta, ElementName=Root}"
                 TextTrimming="CharacterEllipsis" />
    </StackPanel>
  </Border>
</UserControl>
