<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="using:TOrbit.Designer.Controls"
             x:Class="TOrbit.Designer.Controls.LogViewer"
             x:DataType="controls:LogViewer"
             x:Name="Root">
  <Border Classes="card" Padding="0">
    <Grid RowDefinitions="Auto,*">

      <!-- Header -->
      <Grid Grid.Row="0"
            ColumnDefinitions="*,Auto"
            ColumnSpacing="12"
            Margin="18,14,16,14">
        <StackPanel Spacing="2" VerticalAlignment="Center">
          <TextBlock Classes="subsection-title"
                     Text="{Binding Title, ElementName=Root}" />
          <TextBlock Classes="caption-muted"
                     Text="{Binding Description, ElementName=Root}"
                     MinHeight="0" />
        </StackPanel>
        <ContentPresenter Grid.Column="1"
                          Content="{Binding ActionContent, ElementName=Root}"
                          VerticalAlignment="Center" />
      </Grid>

      <!-- Log output -->
      <Border Grid.Row="1"
              Background="{DynamicResource TOrbitBackgroundBrush}"
              BorderBrush="{DynamicResource TOrbitBorderBrush}"
              BorderThickness="0,1,0,0"
              CornerRadius="0,0,14,14">
        <TextBox Text="{Binding Text, ElementName=Root}"
                 IsReadOnly="True"
                 AcceptsReturn="True"
                 TextWrapping="Wrap"
                 VerticalContentAlignment="Top"
                 FontFamily="{DynamicResource TOrbitMonoFontFamily}"
                 FontSize="12"
                 LineHeight="18"
                 Foreground="{DynamicResource TOrbitTextSecondaryBrush}"
                 Background="Transparent"
                 BorderThickness="0"
                 Padding="16,12"
                 ScrollViewer.HorizontalScrollBarVisibility="Auto"
                 ScrollViewer.VerticalScrollBarVisibility="Auto" />
      </Border>

    </Grid>
  </Border>
</UserControl>
