<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="using:TOrbit.Designer.Controls"
             x:Class="TOrbit.Designer.Controls.SectionCard"
             x:DataType="controls:SectionCard"
             x:Name="Root">
  <Border Classes="card">
    <StackPanel Spacing="0">

      <!-- Header -->
      <StackPanel Spacing="3" Margin="0,0,0,14">
        <TextBlock Classes="section-title"
                   Text="{Binding Title, ElementName=Root}" />
        <TextBlock Classes="caption-muted"
                   MinHeight="0"
                   Text="{Binding Description, ElementName=Root}"
                   TextWrapping="Wrap" />
      </StackPanel>

      <!-- Separator -->
      <Border BorderBrush="{DynamicResource TOrbitBorderBrush}"
              BorderThickness="0,1,0,0"
              Margin="0,0,0,16" />

      <!-- Body -->
      <ContentPresenter Content="{Binding Body, ElementName=Root}" />

    </StackPanel>
  </Border>
</UserControl>
