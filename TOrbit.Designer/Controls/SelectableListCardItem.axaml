<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="using:TOrbit.Designer.Controls"
             x:Class="TOrbit.Designer.Controls.SelectableListCardItem"
             x:DataType="controls:SelectableListCardItem"
             x:Name="Root">
  <UserControl.Styles>
    <Style Selector="Border#Card">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderBrush" Value="Transparent" />
      <Setter Property="BorderThickness" Value="3,0,0,0" />
      <Setter Property="CornerRadius" Value="{DynamicResource TOrbitRadiusMedium}" />
      <Setter Property="Transitions">
        <Transitions>
          <BrushTransition Property="Background" Duration="0:0:0.1" />
          <BrushTransition Property="BorderBrush" Duration="0:0:0.1" />
        </Transitions>
      </Setter>
    </Style>
    <Style Selector="Border#Card:pointerover">
      <Setter Property="Background" Value="{DynamicResource TOrbitSurfaceHoverBrush}" />
    </Style>
    <Style Selector="UserControl.selected Border#Card">
      <Setter Property="Background" Value="{DynamicResource TOrbitAccentSubtleBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource TOrbitAccentBrush}" />
    </Style>
    <Style Selector="UserControl.selected Border#Card TextBlock">
      <Setter Property="Foreground" Value="{DynamicResource TOrbitAccentSubtleForegroundBrush}" />
    </Style>
  </UserControl.Styles>

  <Border x:Name="Card"
          Margin="0"
          Padding="14,10"
          MinHeight="52">
    <Grid ColumnDefinitions="*,Auto"
          ColumnSpacing="12"
          VerticalAlignment="Center">
      <ContentPresenter Content="{Binding BodyContent, ElementName=Root}"
                        VerticalAlignment="Center" />
      <ContentPresenter Grid.Column="1"
                        Content="{Binding ActionContent, ElementName=Root}"
                        VerticalAlignment="Center" />
    </Grid>
  </Border>
</UserControl>
