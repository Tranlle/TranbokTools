<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="using:TOrbit.Designer.Controls"
             x:Class="TOrbit.Designer.Controls.SplitWorkspace"
             x:DataType="controls:SplitWorkspace"
             x:Name="Root">
  <UserControl.Styles>
    <Style Selector="GridSplitter.workspace-splitter">
      <Setter Property="Background" Value="{DynamicResource TOrbitBorderBrush}" />
      <Setter Property="HorizontalAlignment" Value="Center" />
      <Setter Property="VerticalAlignment" Value="Stretch" />
      <Setter Property="Width" Value="1" />
      <Setter Property="Cursor" Value="SizeWestEast" />
      <Setter Property="Margin" Value="7,0" />
      <Setter Property="Opacity" Value="0.5" />
      <Setter Property="Transitions">
        <Transitions>
          <BrushTransition Property="Background" Duration="0:0:0.12" />
          <DoubleTransition Property="Opacity" Duration="0:0:0.12" />
        </Transitions>
      </Setter>
    </Style>
    <Style Selector="GridSplitter.workspace-splitter:pointerover">
      <Setter Property="Background" Value="{DynamicResource TOrbitAccentBrush}" />
      <Setter Property="Opacity" Value="1" />
    </Style>
    <Style Selector="GridSplitter.workspace-splitter:pressed">
      <Setter Property="Background" Value="{DynamicResource TOrbitAccentBrush}" />
      <Setter Property="Opacity" Value="1" />
    </Style>
  </UserControl.Styles>

  <Grid>
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="{Binding LeftWidth, ElementName=Root}"
                        MinWidth="{Binding LeftMinWidth, ElementName=Root}" />
      <ColumnDefinition Width="16" />
      <ColumnDefinition Width="*"
                        MinWidth="{Binding RightMinWidth, ElementName=Root}" />
    </Grid.ColumnDefinitions>

    <ContentPresenter Content="{Binding LeftContent, ElementName=Root}" />

    <GridSplitter Grid.Column="1"
                  Classes="workspace-splitter"
                  ResizeDirection="Columns" />

    <ContentPresenter Grid.Column="2"
                      Content="{Binding RightContent, ElementName=Root}" />
  </Grid>
</UserControl>
