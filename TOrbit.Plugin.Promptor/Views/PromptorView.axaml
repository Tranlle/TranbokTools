<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:TOrbit.Plugin.Promptor.ViewModels"
             xmlns:designer="using:TOrbit.Designer.Controls"
             xmlns:loc="using:TOrbit.Designer.Markup"
             x:DataType="vm:PromptorViewModel"
             x:Class="TOrbit.Plugin.Promptor.Views.PromptorView"
             MinHeight="0"
             VerticalAlignment="Stretch">

  <UserControl.Styles>
    <Style Selector="ComboBox.inline-compact">
      <Setter Property="Height" Value="34" />
      <Setter Property="MinHeight" Value="34" />
      <Setter Property="Padding" Value="10,0" />
      <Setter Property="FontSize" Value="13" />
      <Setter Property="VerticalAlignment" Value="Center" />
      <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>
  </UserControl.Styles>

  <designer:ToolPageLayout FooterHeight="0"
                           BodyFooterGapHeight="0"
                           MinHeight="0"
                           VerticalAlignment="Stretch">
    <designer:ToolPageLayout.BodyContent>
      <Grid RowDefinitions="Auto,*"
            RowSpacing="14"
            MinHeight="0"
            VerticalAlignment="Stretch">
        <Grid ColumnDefinitions="Auto,*,Auto"
              ColumnSpacing="12"
              VerticalAlignment="Center">
          <ComboBox Classes="inline-compact"
                    MinWidth="160"
                    ItemsSource="{Binding StrategyOptions}"
                    SelectedIndex="0"
                    SelectedItem="{Binding SelectedStrategyOption, Mode=TwoWay}"
                    DisplayMemberBinding="{Binding Label}" />

          <TextBlock Grid.Column="1"
                     Text="{Binding StrategyDescription}"
                     Classes="caption-muted"
                     MinHeight="0"
                     VerticalAlignment="Center"
                     TextWrapping="Wrap" />

          <StackPanel Grid.Column="2"
                      Orientation="Horizontal"
                      Spacing="8"
                      VerticalAlignment="Center">
            <Button Content="{loc:Loc promptor.apiSettings}"
                    Command="{Binding OpenApiSettingsCommand}" />
            <Button Content="{loc:Loc promptor.log}"
                    Command="{Binding ShowLogCommand}" />
            <Border Background="{DynamicResource TOrbitSurfaceHoverBrush}"
                    BorderBrush="{DynamicResource TOrbitBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="999"
                    Padding="10,4">
              <TextBlock Text="{Binding StatusMessage}"
                         FontSize="11"
                         FontWeight="Medium" />
            </Border>
            <Button Content="{loc:Loc promptor.cancel}"
                    Command="{Binding CancelCommand}"
                    IsVisible="{Binding IsBusy}" />
          </StackPanel>
        </Grid>

        <designer:SplitWorkspace Grid.Row="1"
                                 LeftWidth="*"
                                 LeftMinWidth="320"
                                 RightMinWidth="320"
                                 MinHeight="0"
                                 VerticalAlignment="Stretch">
          <designer:SplitWorkspace.LeftContent>
            <designer:CardTextEditor Eyebrow="{loc:Loc promptor.inputEyebrow}"
                                     Title="{loc:Loc promptor.inputTitle}"
                                     Description="{loc:Loc promptor.inputDescription}"
                                     Text="{Binding RawInput, Mode=TwoWay}"
                                     PlaceholderText="{loc:Loc promptor.inputPlaceholder}"
                                     AcceptsReturn="True"
                                     AcceptsTab="True"
                                     SubmitCommand="{Binding OptimizeCommand}"
                                     MinHeight="0"
                                     VerticalAlignment="Stretch">
              <designer:CardTextEditor.ActionContent>
                <StackPanel Orientation="Horizontal"
                            Spacing="8">
                  <Button Content="{loc:Loc promptor.clear}"
                          Command="{Binding ClearAllCommand}"
                          IsEnabled="{Binding HasRawInput}" />
                  <Button Content="{loc:Loc promptor.optimize}"
                          Command="{Binding OptimizeCommand}"
                          IsEnabled="{Binding CanOptimize}"
                          Classes="accent" />
                </StackPanel>
              </designer:CardTextEditor.ActionContent>
            </designer:CardTextEditor>
          </designer:SplitWorkspace.LeftContent>

          <designer:SplitWorkspace.RightContent>
            <designer:CardTextEditor Eyebrow="{loc:Loc promptor.outputEyebrow}"
                                     Title="{loc:Loc promptor.outputTitle}"
                                     Description="{loc:Loc promptor.outputDescription}"
                                     Text="{Binding OptimizedOutput, Mode=TwoWay}"
                                     PlaceholderText="{loc:Loc promptor.outputPlaceholder}"
                                     IsReadOnly="True"
                                     MinHeight="0"
                                     VerticalAlignment="Stretch">
              <designer:CardTextEditor.ActionContent>
                <StackPanel Orientation="Horizontal"
                            Spacing="8">
                  <Button Content="{loc:Loc promptor.copy}"
                          Command="{Binding CopyCommand}"
                          IsEnabled="{Binding HasOptimizedOutput}" />
                  <Button Content="{loc:Loc promptor.clear}"
                          Command="{Binding ClearOutputCommand}"
                          IsEnabled="{Binding HasOptimizedOutput}" />
                </StackPanel>
              </designer:CardTextEditor.ActionContent>
            </designer:CardTextEditor>
          </designer:SplitWorkspace.RightContent>
        </designer:SplitWorkspace>
      </Grid>
    </designer:ToolPageLayout.BodyContent>
  </designer:ToolPageLayout>
</UserControl>
