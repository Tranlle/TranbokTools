<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:designer="using:TOrbit.Designer.Controls"
             xmlns:loc="using:TOrbit.Designer.Markup"
             xmlns:vm="using:TOrbit.Plugin.RuntimeHost.ViewModels"
             x:Class="TOrbit.Plugin.RuntimeHost.Views.RuntimeHostDetailsSheetView"
             x:DataType="vm:RuntimeHostViewModel">
  <StackPanel Spacing="18">
    <Border Classes="runtime-panel">
      <Grid RowDefinitions="Auto,Auto,Auto,Auto"
            RowSpacing="18">
        <Grid ColumnDefinitions="*,Auto"
              ColumnSpacing="16">
          <StackPanel Spacing="3">
            <TextBlock Classes="eyebrow"
                       Text="{loc:Loc runtime.profile}" />
            <TextBlock Classes="section-title"
                       Text="{loc:Loc runtime.runtimeDefinition}" />
            <TextBlock Classes="caption-muted"
                       Text="{loc:Loc runtime.runtimeDefinitionDescription}"
                       TextWrapping="Wrap" />
          </StackPanel>
          <StackPanel Grid.Column="1"
                      Orientation="Horizontal"
                      Spacing="8">
            <Button Content="{loc:Loc settings.header.actions.save}"
                    Command="{Binding SaveProfileCommand}" />
            <Button Content="{loc:Loc runtime.delete}"
                    Command="{Binding RemoveProfileCommand}" />
          </StackPanel>
        </Grid>

        <Grid Grid.Row="1"
              ColumnDefinitions="*,*"
              ColumnSpacing="18"
              RowDefinitions="Auto,Auto,Auto,Auto">
          <StackPanel Spacing="6">
            <TextBlock Classes="field-label"
                       Text="{loc:Loc runtime.name}" />
            <TextBox Text="{Binding EditingName, Mode=TwoWay}" />
          </StackPanel>
          <StackPanel Grid.Column="1"
                      Spacing="6">
            <TextBlock Classes="field-label"
                       Text="{loc:Loc runtime.deployFolder}" />
            <TextBox Text="{Binding EditingDeployFolderName, Mode=TwoWay}" />
          </StackPanel>
          <StackPanel Grid.Row="1"
                      Grid.ColumnSpan="2"
                      Spacing="6">
            <TextBlock Classes="field-label"
                       Text="{loc:Loc runtime.description}" />
            <TextBox Text="{Binding EditingDescription, Mode=TwoWay}"
                     AcceptsReturn="True"
                     TextWrapping="Wrap"
                     MinHeight="72" />
          </StackPanel>
          <StackPanel Grid.Row="2"
                      Grid.ColumnSpan="2"
                      Spacing="6">
            <TextBlock Classes="field-label"
                       Text="{loc:Loc runtime.entryRelativePath}" />
            <TextBox Text="{Binding EditingEntryRelativePath, Mode=TwoWay}" />
          </StackPanel>
          <Grid Grid.Row="3"
                Grid.ColumnSpan="2"
                ColumnDefinitions="Auto,Auto,*"
                ColumnSpacing="18">
            <CheckBox IsChecked="{Binding EditingRunWithDotnet, Mode=TwoWay}"
                      Content="{loc:Loc runtime.runWithDotnetHost}"
                      VerticalAlignment="Center" />
            <CheckBox Grid.Column="1"
                      IsChecked="{Binding EditingAutoStart, Mode=TwoWay}"
                      Content="{loc:Loc runtime.autoStartOnHostLoad}"
                      VerticalAlignment="Center" />
            <TextBlock Grid.Column="2"
                       Classes="caption-muted"
                       Text="{Binding SelectedEntryMode}"
                       VerticalAlignment="Center"
                       HorizontalAlignment="Right" />
          </Grid>
        </Grid>

        <Grid Grid.Row="2"
              ColumnDefinitions="1.25*,*"
              ColumnSpacing="18">
          <StackPanel Spacing="6">
            <TextBlock Classes="field-label"
                       Text="{loc:Loc runtime.startupEnvironmentVariables}" />
            <TextBox Text="{Binding EnvironmentVariablesText, Mode=TwoWay}"
                     AcceptsReturn="True"
                     TextWrapping="NoWrap"
                     FontFamily="{DynamicResource TOrbitMonoFontFamily}"
                     Height="160"
                     PlaceholderText="{loc:Loc runtime.environmentPlaceholder}" />
            <TextBlock Classes="caption-muted"
                       Text="{loc:Loc runtime.environmentHelp}"
                       TextWrapping="Wrap" />
          </StackPanel>

          <Border Grid.Column="1"
                  Background="{DynamicResource TOrbitBackgroundBrush}"
                  BorderBrush="{DynamicResource TOrbitBorderBrush}"
                  BorderThickness="1"
                  CornerRadius="{DynamicResource TOrbitRadiusLarge}"
                  Padding="14">
            <StackPanel Spacing="12">
              <TextBlock Classes="field-label"
                         Text="{loc:Loc runtime.runtimeSnapshot}" />
              <designer:PropertyGrid ItemsSource="{Binding SelectedRuntimeProperties}" />
            </StackPanel>
          </Border>
        </Grid>

        <Grid Grid.Row="3"
              ColumnDefinitions="Auto,Auto,Auto,*"
              ColumnSpacing="10">
          <Button Content="{loc:Loc runtime.deployZip}"
                  Command="{Binding DeployPackageCommand}" />
          <Button Grid.Column="1"
                  Content="{loc:Loc runtime.start}"
                  Command="{Binding StartCommand}"
                  IsEnabled="{Binding CanStart}" />
          <Button Grid.Column="2"
                  Content="{loc:Loc runtime.stop}"
                  Command="{Binding StopCommand}"
                  IsEnabled="{Binding CanStop}" />
          <Button Grid.Column="3"
                  Content="{loc:Loc runtime.restart}"
                  HorizontalAlignment="Left"
                  Command="{Binding RestartCommand}"
                  IsEnabled="{Binding CanRestart}" />
        </Grid>
      </Grid>
    </Border>

    <Border Classes="runtime-panel">
      <StackPanel Spacing="10">
        <TextBlock Classes="eyebrow"
                   Text="{loc:Loc runtime.storage}" />
        <TextBlock Classes="section-title"
                   Text="{loc:Loc runtime.deploymentWorkspace}" />
        <TextBlock Classes="caption-muted"
                   Text="{Binding StatusMessage}"
                   TextWrapping="Wrap" />
        <designer:PropertyGrid ItemsSource="{Binding SelectedRuntimeProperties}" />
        <Grid ColumnDefinitions="Auto,*"
              ColumnSpacing="14">
          <TextBlock Classes="field-label"
                     Text="{loc:Loc runtime.deployPath}" />
          <TextBlock Grid.Column="1"
                     Text="{Binding SelectedDeployPath}"
                     TextWrapping="Wrap" />
        </Grid>
        <Grid ColumnDefinitions="Auto,*"
              ColumnSpacing="14">
          <TextBlock Classes="field-label"
                     Text="{loc:Loc runtime.logsPath}" />
          <TextBlock Grid.Column="1"
                     Text="{Binding SelectedLogsPath}"
                     TextWrapping="Wrap" />
        </Grid>
      </StackPanel>
    </Border>
  </StackPanel>
</UserControl>
