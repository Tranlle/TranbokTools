<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:TOrbit.Plugin.RuntimeHost.ViewModels"
             xmlns:designer="using:TOrbit.Designer.Controls"
             xmlns:materialIcons="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
             xmlns:loc="using:TOrbit.Designer.Markup"
             x:Class="TOrbit.Plugin.RuntimeHost.Views.RuntimeHostView"
             x:DataType="vm:RuntimeHostViewModel"
             x:Name="Root">

  <UserControl.Styles>
    <Style Selector="Border.runtime-list-item">
      <Setter Property="Background" Value="{DynamicResource TOrbitSurfaceElevatedBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource TOrbitBorderBrush}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="{DynamicResource TOrbitRadiusLarge}" />
      <Setter Property="Padding" Value="16" />
      <Setter Property="Transitions">
        <Transitions>
          <BrushTransition Property="Background" Duration="0:0:0.16" />
          <BrushTransition Property="BorderBrush" Duration="0:0:0.16" />
          <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.18" />
        </Transitions>
      </Setter>
      <Setter Property="RenderTransform" Value="translateY(0px)" />
    </Style>

    <Style Selector="Border.runtime-list-item:pointerover">
      <Setter Property="BorderBrush" Value="{DynamicResource TOrbitBorderHoverBrush}" />
      <Setter Property="RenderTransform" Value="translateY(-1px)" />
    </Style>

    <Style Selector="Border.runtime-list-item.selected">
      <Setter Property="Background" Value="{DynamicResource TOrbitAccentSubtleBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource TOrbitAccentBrush}" />
    </Style>

    <Style Selector="Button.runtime-icon-button">
      <Setter Property="Width" Value="34" />
      <Setter Property="Height" Value="34" />
      <Setter Property="MinHeight" Value="34" />
      <Setter Property="Padding" Value="0" />
      <Setter Property="CornerRadius" Value="999" />
      <Setter Property="Background" Value="{DynamicResource TOrbitSurfaceHoverBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource TOrbitBorderBrush}" />
    </Style>

    <Style Selector="Button.runtime-icon-button:pointerover">
      <Setter Property="BorderBrush" Value="{DynamicResource TOrbitAccentBrush}" />
    </Style>

    <Style Selector="Border.runtime-panel">
      <Setter Property="Background" Value="{DynamicResource TOrbitSurfaceElevatedBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource TOrbitBorderBrush}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="{DynamicResource TOrbitRadiusLarge}" />
      <Setter Property="Padding" Value="18" />
    </Style>
  </UserControl.Styles>

  <designer:ToolPageLayout>
    <designer:ToolPageLayout.BodyContent>
      <Grid RowDefinitions="*,220"
            RowSpacing="18">
        <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                      VerticalScrollBarVisibility="Auto">
          <StackPanel Spacing="18">
            <Border Classes="runtime-panel"
                    Padding="0">
              <Grid RowDefinitions="Auto,*">
                <Grid ColumnDefinitions="*,Auto"
                      Margin="18,16,18,14"
                      ColumnSpacing="12">
                  <StackPanel Spacing="3">
                    <TextBlock Classes="eyebrow"
                               Text="{loc:Loc runtime.workspace}" />
                    <TextBlock Classes="section-title"
                               Text="{loc:Loc runtime.managedApps}" />
                    <TextBlock Classes="caption-muted"
                               Text="{loc:Loc runtime.managedAppsDescription}"
                               TextWrapping="Wrap" />
                  </StackPanel>
                  <Button Grid.Column="1"
                          Content="{loc:Loc runtime.add}"
                          Command="{Binding AddProfileCommand}"
                          HorizontalAlignment="Right"
                          VerticalAlignment="Top" />
                </Grid>

                <StackPanel Grid.Row="1"
                            Margin="12,0,12,12"
                            Spacing="12">
                  <ItemsControl ItemsSource="{Binding Apps}">
                    <ItemsControl.ItemsPanel>
                      <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal"
                                   ItemWidth="360"
                                   ItemHeight="260" />
                      </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                      <DataTemplate x:DataType="vm:HostedAppItemViewModel">
                        <Border Classes="runtime-list-item"
                                Classes.selected="{Binding IsSelected}"
                                Width="344"
                                Height="244"
                                Margin="0,0,12,12"
                                Tapped="AppCard_OnTapped"
                                DoubleTapped="AppCard_OnDoubleTapped">
                          <Grid RowDefinitions="Auto,Auto,*,Auto"
                                RowSpacing="12">
                            <Grid ColumnDefinitions="Auto,*,Auto"
                                  ColumnSpacing="12">
                              <Border Width="44"
                                      Height="44"
                                      Background="{DynamicResource TOrbitSurfaceHoverBrush}"
                                      CornerRadius="14"
                                      VerticalAlignment="Top">
                                <materialIcons:MaterialIcon Kind="RocketLaunch"
                                                            Width="22"
                                                            Height="22"
                                                            HorizontalAlignment="Center"
                                                            VerticalAlignment="Center"
                                                            Foreground="{Binding StatusBrush}" />
                              </Border>

                              <StackPanel Grid.Column="1"
                                          Spacing="2">
                                <TextBlock Text="{Binding Name}"
                                           FontSize="16"
                                           FontWeight="SemiBold"
                                           TextTrimming="CharacterEllipsis" />
                                <TextBlock Text="{Binding Id}"
                                           Classes="caption-muted"
                                           MinHeight="0"
                                           TextTrimming="CharacterEllipsis" />
                              </StackPanel>

                              <StackPanel Grid.Column="2"
                                          Orientation="Horizontal"
                                          Spacing="6">
                                <Button Classes="runtime-icon-button"
                                        Command="{Binding #Root.DataContext.StartAppCommand}"
                                        CommandParameter="{Binding}"
                                        IsEnabled="{Binding CanStart}">
                                  <materialIcons:MaterialIcon Kind="Play"
                                                              Width="16"
                                                              Height="16" />
                                </Button>
                                <Button Classes="runtime-icon-button"
                                        Command="{Binding #Root.DataContext.RestartAppCommand}"
                                        CommandParameter="{Binding}"
                                        IsEnabled="{Binding CanRestart}">
                                  <materialIcons:MaterialIcon Kind="Refresh"
                                                              Width="16"
                                                              Height="16" />
                                </Button>
                                <Button Classes="runtime-icon-button"
                                        Command="{Binding #Root.DataContext.StopAppCommand}"
                                        CommandParameter="{Binding}"
                                        IsEnabled="{Binding CanStop}">
                                  <materialIcons:MaterialIcon Kind="Stop"
                                                              Width="16"
                                                              Height="16" />
                                </Button>
                              </StackPanel>
                            </Grid>

                            <Grid Grid.Row="1"
                                  ColumnDefinitions="Auto,*"
                                  ColumnSpacing="10">
                              <Border Background="{DynamicResource TOrbitSurfaceHoverBrush}"
                                      BorderBrush="{DynamicResource TOrbitBorderBrush}"
                                      BorderThickness="1"
                                      CornerRadius="999"
                                      Padding="10,4"
                                      HorizontalAlignment="Left">
                                <TextBlock Text="{Binding StatusLabel}"
                                           FontSize="11"
                                           Foreground="{Binding StatusBrush}" />
                              </Border>
                              <TextBlock Grid.Column="1"
                                         Text="{Binding StatusSummary}"
                                         Classes="caption-muted"
                                         VerticalAlignment="Center"
                                         TextTrimming="CharacterEllipsis" />
                            </Grid>

                            <StackPanel Grid.Row="2"
                                        Spacing="10">
                              <TextBlock Text="{Binding Description}"
                                         Classes="caption-muted"
                                         MaxLines="2"
                                         TextWrapping="Wrap" />

                              <Grid ColumnDefinitions="*,*"
                                    ColumnSpacing="12">
                                <StackPanel Spacing="2">
                                  <TextBlock Classes="caption-muted"
                                             Text="{loc:Loc runtime.entry}" />
                                  <TextBlock Text="{Binding EntryRelativePath}"
                                             FontSize="12"
                                             TextTrimming="CharacterEllipsis" />
                                </StackPanel>
                                <StackPanel Grid.Column="1"
                                            Spacing="2">
                                  <TextBlock Classes="caption-muted"
                                             Text="{loc:Loc runtime.uptime}" />
                                  <TextBlock Text="{Binding UptimeLabel}"
                                             FontSize="12" />
                                </StackPanel>
                              </Grid>

                              <Grid ColumnDefinitions="*,*"
                                    ColumnSpacing="12">
                                <StackPanel Spacing="2">
                                  <TextBlock Classes="caption-muted"
                                             Text="{loc:Loc runtime.deploy}" />
                                  <TextBlock Text="{Binding LastDeployLabel}"
                                             FontSize="12"
                                             TextTrimming="CharacterEllipsis" />
                                </StackPanel>
                                <StackPanel Grid.Column="1"
                                            Spacing="2">
                                  <TextBlock Classes="caption-muted"
                                             Text="{loc:Loc runtime.mode}" />
                                  <TextBlock Text="{Binding StartupModeLabel}"
                                             FontSize="12"
                                             TextTrimming="CharacterEllipsis" />
                                </StackPanel>
                              </Grid>
                            </StackPanel>

                            <TextBlock Grid.Row="3"
                                       Text="{Binding LastError}"
                                       Classes="caption-muted"
                                       MaxLines="1"
                                       TextTrimming="CharacterEllipsis"
                                       IsVisible="{Binding HasError}" />
                          </Grid>
                        </Border>
                      </DataTemplate>
                    </ItemsControl.ItemTemplate>
                  </ItemsControl>

                  <designer:EmptyState IsVisible="{Binding !HasApps}"
                                       Title="{loc:Loc runtime.emptyTitle}"
                                       Description="{loc:Loc runtime.emptyDescription}" />
                </StackPanel>
              </Grid>
            </Border>

          </StackPanel>
        </ScrollViewer>

        <designer:LogViewer Grid.Row="1"
                            Title="{loc:Loc runtime.runtimeLog}"
                            Description="{loc:Loc runtime.runtimeLogDescription}"
                            Text="{Binding OutputLog}">
          <designer:LogViewer.ActionContent>
            <Button Content="{loc:Loc promptor.clear}"
                    Command="{Binding ClearLogCommand}" />
          </designer:LogViewer.ActionContent>
        </designer:LogViewer>
      </Grid>
    </designer:ToolPageLayout.BodyContent>
  </designer:ToolPageLayout>
</UserControl>
