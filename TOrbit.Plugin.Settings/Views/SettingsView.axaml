<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:TOrbit.Plugin.Settings.ViewModels"
             xmlns:designer="using:TOrbit.Designer.Controls"
             xmlns:models="using:TOrbit.Designer.Models"
             x:Class="TOrbit.Plugin.Settings.Views.SettingsView"
             x:DataType="vm:SettingsViewModel">
  <designer:ToolPageLayout HeaderBodyGapHeight="0"
                           BodyFooterGapHeight="0"
                           FooterHeight="0">
    <designer:ToolPageLayout.BodyContent>
      <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                    VerticalScrollBarVisibility="Auto">
        <StackPanel Spacing="16">

          <!-- ═══ 主题设置 ═══════════════════════════════════════════ -->
          <designer:SectionCard Title="主题设置"
                                Description="管理配色方案与全局字体。">
            <designer:SectionCard.Body>
              <Grid ColumnDefinitions="*,20,*"
                    RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto"
                    RowSpacing="14">
                <designer:FormField Grid.Row="0" Grid.Column="0" Label="应用名称">
                  <designer:FormField.Body>
                    <TextBox Classes="form-control"
                             Text="{Binding AppName, Mode=TwoWay}"
                             PlaceholderText="应用名称" />
                  </designer:FormField.Body>
                </designer:FormField>

                <designer:FormField Grid.Row="1" Grid.ColumnSpan="3"
                                    Label="内置配色方案"
                                    Description="{Binding SelectedPaletteOption.Description, TargetNullValue=''}">
                  <designer:FormField.Body>
                    <ComboBox Classes="form-control"
                              ItemsSource="{Binding PaletteOptions}"
                              SelectedItem="{Binding SelectedPaletteOption, Mode=TwoWay}"
                              DisplayMemberBinding="{Binding Label}" />
                  </designer:FormField.Body>
                </designer:FormField>

                <designer:FormField Grid.Row="2" Grid.ColumnSpan="3"
                                    Label="全局字体"
                                    Description="{Binding SelectedFontOption.Description, TargetNullValue=''}">
                  <designer:FormField.Body>
                    <ComboBox Classes="form-control"
                              ItemsSource="{Binding FontOptions}"
                              SelectedItem="{Binding SelectedFontOption, Mode=TwoWay}"
                              DisplayMemberBinding="{Binding Label}" />
                  </designer:FormField.Body>
                </designer:FormField>

                <Border Grid.Row="3"
                        Grid.ColumnSpan="3"
                        IsVisible="{Binding IsInterFontWarningVisible}"
                        Background="{DynamicResource TOrbitBadgeWarningBackgroundBrush}"
                        BorderBrush="{DynamicResource TOrbitBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="{DynamicResource TOrbitRadiusSmall}"
                        Padding="12,9">
                  <TextBlock Text="{Binding FontWarningMessage}"
                             FontSize="12"
                             Foreground="{DynamicResource TOrbitBadgeWarningForegroundBrush}"
                             TextWrapping="Wrap" />
                </Border>

                <designer:FormField Grid.Row="4" Grid.ColumnSpan="3"
                                    Label="关闭按钮行为"
                                    Description="关闭主窗口时最小化到系统托盘，或直接退出应用。">
                  <designer:FormField.Body>
                    <ToggleSwitch IsChecked="{Binding MinimizeToTrayOnClose, Mode=TwoWay}"
                                  OnContent="最小化到托盘"
                                  OffContent="直接退出" />
                  </designer:FormField.Body>
                </designer:FormField>

                <CheckBox Grid.Row="5" Grid.ColumnSpan="3"
                          Content="迁移默认启用 Workspace 模式"
                          IsChecked="{Binding UseWorkspaceForMigrations, Mode=TwoWay}" />
              </Grid>
            </designer:SectionCard.Body>
          </designer:SectionCard>

          <!-- ═══ 高级主题 ══════════════════════════════════════════ -->
          <designer:SectionCard Title="高级主题"
                                Description="自定义 palette 扩展入口。">
            <designer:SectionCard.Body>
              <StackPanel Spacing="14">
                <CheckBox Content="显示高级主题设置"
                          IsChecked="{Binding ShowAdvancedThemeSettings, Mode=TwoWay}" />
                <StackPanel Spacing="14" IsVisible="{Binding ShowAdvancedThemeSettings}">
                  <designer:FormField Label="高级主题方案"
                                      Description="{Binding SelectedAdvancedPaletteOption.Description, TargetNullValue=''}">
                    <designer:FormField.Body>
                      <ComboBox Classes="form-control"
                                ItemsSource="{Binding AdvancedPaletteOptions}"
                                SelectedItem="{Binding SelectedAdvancedPaletteOption, Mode=TwoWay}"
                                DisplayMemberBinding="{Binding Label}" />
                    </designer:FormField.Body>
                  </designer:FormField>
                  <designer:FormField Label="自定义主题目录">
                    <designer:FormField.Body>
                      <TextBox Classes="form-control"
                               Text="{Binding CustomThemeDirectory, Mode=TwoWay}" />
                    </designer:FormField.Body>
                  </designer:FormField>
                </StackPanel>
              </StackPanel>
            </designer:SectionCard.Body>
          </designer:SectionCard>

          <!-- ═══ 工作区 ════════════════════════════════════════════ -->
          <designer:SectionCard Title="工作区"
                                Description="配置当前工具宿主的工作区路径。">
            <designer:SectionCard.Body>
              <designer:FormField Label="工作区路径">
                <designer:FormField.Body>
                  <TextBox Classes="form-control"
                           Text="{Binding WorkspaceRoot, Mode=TwoWay}" />
                </designer:FormField.Body>
              </designer:FormField>
            </designer:SectionCard.Body>
          </designer:SectionCard>

          <!-- ═══ 插件变量管理 ════════════════════════════════════ -->
          <designer:SectionCard Title="插件变量管理"
                                Description="集中配置各插件所需的环境变量，加密字段由各插件自行处理。">
            <designer:SectionCard.Body>
              <StackPanel Spacing="12">

                <!-- Toolbar -->
                <Grid ColumnDefinitions="*,Auto">
                  <TextBlock Grid.Column="0"
                             Classes="caption-muted"
                             VerticalAlignment="Center"
                             Text="{Binding PluginVariableSummary}" />
                  <Button Grid.Column="1"
                          Command="{Binding ShowAddVariableFormCommand}"
                          IsVisible="{Binding !ShowAddVariableForm}"
                          Classes="accent"
                          Content="新建变量" />
                </Grid>

                <!-- Add variable panel -->
                <Border IsVisible="{Binding ShowAddVariableForm}"
                        Background="{DynamicResource TOrbitSurfaceHoverBrush}"
                        BorderBrush="{DynamicResource TOrbitAccentBrush}"
                        BorderThickness="1"
                        CornerRadius="{DynamicResource TOrbitRadiusMedium}"
                        Padding="16">
                  <StackPanel Spacing="12">
                    <TextBlock Classes="subsection-title" Text="新建插件变量" />

                    <Grid ColumnDefinitions="*,16,*" RowSpacing="10">
                      <designer:FormField Grid.Column="0" Label="所属插件">
                        <designer:FormField.Body>
                          <ComboBox Classes="form-control"
                                    ItemsSource="{Binding PluginOptions}"
                                    SelectedItem="{Binding AddFormSelectedPlugin, Mode=TwoWay}"
                                    DisplayMemberBinding="{Binding Label}" />
                        </designer:FormField.Body>
                      </designer:FormField>
                      <designer:FormField Grid.Column="2" Label="变量键">
                        <designer:FormField.Body>
                          <TextBox Classes="form-control"
                                   Text="{Binding AddFormKey, Mode=TwoWay}"
                                   PlaceholderText="例如：MY_API_KEY" />
                        </designer:FormField.Body>
                      </designer:FormField>
                    </Grid>

                    <!-- Key hints -->
                    <StackPanel Spacing="6" IsVisible="{Binding HasAddFormKeyHints}">
                      <TextBlock Classes="caption-muted"
                                 Text="插件已声明的变量键（点击快速填入）：" />
                      <ItemsControl ItemsSource="{Binding AddFormKeyHints}">
                        <ItemsControl.ItemsPanel>
                          <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal" />
                          </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                          <DataTemplate x:DataType="models:DesignerOptionItem">
                            <Button Command="{Binding $parent[UserControl].((vm:SettingsViewModel)DataContext).FillKeyFromHintCommand}"
                                    CommandParameter="{Binding}"
                                    Height="26" MinHeight="26" Padding="10,0"
                                    Margin="0,0,6,6" FontSize="11"
                                    ToolTip.Tip="{Binding Description}">
                              <TextBlock Text="{Binding Label}" FontSize="11" />
                            </Button>
                          </DataTemplate>
                        </ItemsControl.ItemTemplate>
                      </ItemsControl>
                    </StackPanel>

                    <designer:FormField Label="变量值">
                      <designer:FormField.Body>
                        <TextBox Classes="form-control"
                                 Text="{Binding AddFormValue, Mode=TwoWay}"
                                 PlaceholderText="输入该变量的值" />
                      </designer:FormField.Body>
                    </designer:FormField>

                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Right"
                                Spacing="8">
                      <Button Command="{Binding CancelAddVariableCommand}" Content="取消" />
                      <Button Command="{Binding AddVariableCommand}" Classes="accent" Content="添加" />
                    </StackPanel>
                  </StackPanel>
                </Border>

                <!-- Grouped variable list -->
                <ItemsControl ItemsSource="{Binding PluginVariableGroups}"
                              IsVisible="{Binding HasPluginVariables}">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="vm:PluginVariableGroupViewModel">
                      <StackPanel Margin="0,4,0,14">

                        <!-- Group heading -->
                        <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,0,0,8">
                          <TextBlock Text="{Binding PluginName}"
                                     Classes="subsection-title"
                                     VerticalAlignment="Center" />
                          <Border Background="{DynamicResource TOrbitSurfaceElevatedBrush}"
                                  BorderBrush="{DynamicResource TOrbitBorderBrush}"
                                  BorderThickness="1"
                                  CornerRadius="999"
                                  Padding="7,2">
                            <TextBlock Text="{Binding Count}"
                                       FontSize="11"
                                       Foreground="{DynamicResource TOrbitTextMutedBrush}"
                                       VerticalAlignment="Center" />
                          </Border>
                        </StackPanel>

                        <!-- Table header -->
                        <Grid ColumnDefinitions="*,180,32"
                              ColumnSpacing="8"
                              Margin="4,0,4,4">
                          <TextBlock Grid.Column="0" Classes="field-label" Text="变量键" />
                          <TextBlock Grid.Column="1" Classes="field-label" Text="当前值" />
                        </Grid>
                        <Border BorderBrush="{DynamicResource TOrbitBorderBrush}"
                                BorderThickness="0,1,0,0" />

                        <!-- Variable rows -->
                        <ItemsControl ItemsSource="{Binding Variables}">
                          <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="vm:PluginVariableItemViewModel">
                              <Border BorderBrush="{DynamicResource TOrbitBorderBrush}"
                                      BorderThickness="0,0,0,1"
                                      Padding="4,7">
                                <Grid ColumnDefinitions="*,180,32"
                                      ColumnSpacing="8"
                                      VerticalAlignment="Center">

                                  <!-- Key + encrypted badge + description -->
                                  <StackPanel Grid.Column="0" Spacing="2" VerticalAlignment="Center">
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                      <TextBlock Text="{Binding Key}"
                                                 FontFamily="{DynamicResource TOrbitMonoFontFamily}"
                                                 FontSize="12" />
                                      <Border IsVisible="{Binding IsEncrypted}"
                                              Background="{DynamicResource TOrbitBadgeInfoBackgroundBrush}"
                                              CornerRadius="4"
                                              Padding="5,1"
                                              VerticalAlignment="Center">
                                        <TextBlock Text="加密"
                                                   FontSize="10"
                                                   Foreground="{DynamicResource TOrbitBadgeInfoForegroundBrush}" />
                                      </Border>
                                    </StackPanel>
                                    <TextBlock Text="{Binding Description}"
                                               Classes="caption-muted"
                                               IsVisible="{Binding IsFromMetadata}"
                                               TextWrapping="Wrap" />
                                  </StackPanel>

                                  <!-- Editable value -->
                                  <TextBox Grid.Column="1"
                                           Classes="form-control"
                                           Text="{Binding Value, Mode=TwoWay}"
                                           PasswordChar="{Binding PasswordChar}"
                                           Height="30"
                                           MinHeight="30"
                                           VerticalAlignment="Center" />

                                  <!-- Delete button -->
                                  <Button Grid.Column="2"
                                          Command="{Binding DeleteCommand}"
                                          Classes="danger"
                                          Width="30" Height="30"
                                          MinHeight="30" Padding="0"
                                          VerticalAlignment="Center"
                                          HorizontalAlignment="Center"
                                          ToolTip.Tip="删除此变量"
                                          Content="×"
                                          FontSize="14" />
                                </Grid>
                              </Border>
                            </DataTemplate>
                          </ItemsControl.ItemTemplate>
                        </ItemsControl>

                      </StackPanel>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Empty state -->
                <TextBlock Classes="caption-muted"
                           IsVisible="{Binding !HasPluginVariables}"
                           Text="暂无已配置的插件变量，点击「新建变量」添加第一条。" />

              </StackPanel>
            </designer:SectionCard.Body>
          </designer:SectionCard>

        </StackPanel>
      </ScrollViewer>
    </designer:ToolPageLayout.BodyContent>
  </designer:ToolPageLayout>
</UserControl>
