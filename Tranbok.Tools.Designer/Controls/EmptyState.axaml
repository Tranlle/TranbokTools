<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="using:Tranbok.Tools.Designer.Controls"
             x:Class="Tranbok.Tools.Designer.Controls.EmptyState"
             x:DataType="controls:EmptyState"
             x:Name="Root">
  <StackPanel MaxWidth="620"
              Spacing="12"
              HorizontalAlignment="Center">
    <TextBlock Classes="section-title"
               Text="{Binding Title, ElementName=Root}"
               HorizontalAlignment="Center"
               TextAlignment="Center" />
    <TextBlock Classes="caption-muted"
               Text="{Binding Description, ElementName=Root}"
               TextWrapping="Wrap"
               HorizontalAlignment="Center"
               TextAlignment="Center" />
    <ContentPresenter Content="{Binding ActionContent, ElementName=Root}"
                      HorizontalAlignment="Center" />
  </StackPanel>
</UserControl>
