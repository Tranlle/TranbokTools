<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="using:Tranbok.Tools.Designer.Controls"
             x:Class="Tranbok.Tools.Designer.Controls.LogViewer"
             x:DataType="controls:LogViewer"
             x:Name="Root">
  <Border Classes="card">
    <Grid RowDefinitions="Auto,12,*">
      <controls:CardHeader Title="{Binding Title, ElementName=Root}"
                           Description="{Binding Description, ElementName=Root}"
                           ActionContent="{Binding ActionContent, ElementName=Root}" />
      <TextBox Grid.Row="2"
               Text="{Binding Text, ElementName=Root}"
               IsReadOnly="True"
               AcceptsReturn="True"
               TextWrapping="Wrap"
               VerticalContentAlignment="Top"
               ScrollViewer.HorizontalScrollBarVisibility="Auto"
               ScrollViewer.VerticalScrollBarVisibility="Auto" />
    </Grid>
  </Border>
</UserControl>
