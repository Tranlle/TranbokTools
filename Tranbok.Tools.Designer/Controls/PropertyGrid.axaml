<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="using:Tranbok.Tools.Designer.Controls"
             xmlns:models="using:Tranbok.Tools.Designer.Models"
             x:Class="Tranbok.Tools.Designer.Controls.PropertyGrid"
             x:DataType="controls:PropertyGrid"
             x:Name="Root">
  <ItemsControl ItemsSource="{Binding ItemsSource, ElementName=Root}">
    <ItemsControl.ItemsPanel>
      <ItemsPanelTemplate>
        <StackPanel Spacing="10" />
      </ItemsPanelTemplate>
    </ItemsControl.ItemsPanel>
    <ItemsControl.ItemTemplate>
      <DataTemplate x:DataType="models:PropertyGridItem">
        <Grid ColumnDefinitions="Auto,*"
              ColumnSpacing="16">
          <TextBlock Classes="field-label"
                     Width="{Binding LabelColumnWidth, ElementName=Root}"
                     Text="{Binding Label}" />
          <ContentPresenter Grid.Column="1"
                            Content="{Binding Value}"
                            VerticalAlignment="Center" />
        </Grid>
      </DataTemplate>
    </ItemsControl.ItemTemplate>
  </ItemsControl>
</UserControl>
