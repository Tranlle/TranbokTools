<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="using:Tranbok.Tools.Designer.Controls"
             x:Class="Tranbok.Tools.Designer.Controls.SectionCard"
             x:DataType="controls:SectionCard"
             x:Name="Root">
  <Border Classes="card">
    <StackPanel Spacing="0">

      <!-- Header: accent left bar + title/description -->
      <Border BorderBrush="{DynamicResource TranbokAccentBrush}"
              BorderThickness="3,0,0,0"
              Padding="12,2,0,2"
              Margin="0,0,0,12">
        <StackPanel Spacing="4">
          <TextBlock Classes="section-title"
                     Text="{Binding Title, ElementName=Root}" />
          <TextBlock Classes="caption-muted"
                     MinHeight="0"
                     Text="{Binding Description, ElementName=Root}"
                     TextWrapping="Wrap" />
        </StackPanel>
      </Border>

      <!-- Separator -->
      <Border BorderBrush="{DynamicResource TranbokBorderBrush}"
              BorderThickness="0,1,0,0"
              Margin="0,0,0,16" />

      <!-- Body -->
      <ContentPresenter Content="{Binding Body, ElementName=Root}" />

    </StackPanel>
  </Border>
</UserControl>
