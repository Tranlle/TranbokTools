<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="using:Tranbok.Tools.Plugin.KeyMap.Views"
             x:Class="Tranbok.Tools.Plugin.KeyMap.Views.KeyCaptureBox"
             x:DataType="controls:KeyCaptureBox"
             x:Name="Root">
  <Border x:Name="CaptureContainer"
          Background="{DynamicResource TranbokSurfaceElevatedBrush}"
          BorderBrush="{DynamicResource TranbokBorderBrush}"
          BorderThickness="1"
          CornerRadius="{DynamicResource TranbokRadiusSmall}"
          Padding="10,6"
          MinWidth="160"
          MinHeight="36"
          Cursor="Hand"
          PointerPressed="OnPointerPressed">
    <Border.Styles>
      <Style Selector="Border.capturing">
        <Setter Property="BorderBrush" Value="{DynamicResource TranbokAccentBrush}" />
        <Setter Property="Background" Value="{DynamicResource TranbokAccentSubtleBrush}" />
      </Style>
    </Border.Styles>

    <Grid ColumnDefinitions="*,Auto" VerticalAlignment="Center">
      <TextBlock x:Name="DisplayText"
                 Grid.Column="0"
                 VerticalAlignment="Center"
                 FontFamily="{DynamicResource TranbokMonoFontFamily}"
                 FontSize="13" />
      <TextBlock x:Name="HintText"
                 Grid.Column="1"
                 Classes="caption-muted"
                 Text="点击录入"
                 FontSize="11"
                 VerticalAlignment="Center"
                 IsVisible="True" />
    </Grid>
  </Border>
</UserControl>
