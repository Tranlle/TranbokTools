<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Tranbok.Tools.Plugin.Migration.ViewModels"
             xmlns:models="using:Tranbok.Tools.Designer.Models"
             x:Class="Tranbok.Tools.Plugin.Migration.Views.EditProfileSheetView"
             x:DataType="vm:MigrationViewModel">
  <Border Classes="card" Padding="0">
    <StackPanel Spacing="16">
      <TextBlock Classes="section-title" Text="编辑配置" />
      <Grid ColumnDefinitions="*,20,*" RowDefinitions="Auto,Auto,Auto" RowSpacing="16">
        <StackPanel Grid.Row="0" Grid.Column="0" Spacing="8">
          <TextBlock Classes="form-label" Text="项目路径" />
          <TextBox Text="{Binding EditingProjectPath, Mode=TwoWay}" PlaceholderText="请选择 Domain 项目 .csproj 路径" />
        </StackPanel>
        <StackPanel Grid.Row="0" Grid.Column="2" Spacing="8">
          <TextBlock Classes="form-label" Text="配置名称" />
          <TextBox Text="{Binding EditingProfile.ProfileName, Mode=TwoWay}" PlaceholderText="例如 开发环境 / 生产环境" />
        </StackPanel>
        <StackPanel Grid.Row="1" Grid.Column="0" Spacing="8">
          <TextBlock Classes="form-label" Text="数据库类型" />
          <ComboBox ItemsSource="{Binding DbTypeOptions}"
                    SelectedItem="{Binding SelectedEditingDbTypeOption, Mode=TwoWay}">
            <ComboBox.ItemTemplate>
              <DataTemplate x:DataType="models:DesignerOptionItem">
                <TextBlock Text="{Binding Label}" />
              </DataTemplate>
            </ComboBox.ItemTemplate>
          </ComboBox>
        </StackPanel>
        <StackPanel Grid.Row="1" Grid.Column="2" Spacing="8">
          <TextBlock Classes="form-label" Text="DbContext" />
          <TextBox Text="{Binding EditingProfile.ContextName, Mode=TwoWay}" PlaceholderText="例如 AppDbContext" />
        </StackPanel>
        <StackPanel Grid.Row="2" Grid.ColumnSpan="3" Spacing="8">
          <TextBlock Classes="form-label" Text="连接字符串" />
          <TextBox Text="{Binding EditingProfile.ConnectionString, Mode=TwoWay}" PlaceholderText="请输入数据库连接字符串" />
        </StackPanel>
      </Grid>
    </StackPanel>
  </Border>
</UserControl>
