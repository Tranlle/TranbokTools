<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Tranbok.Tools.Plugin.PluginManager.ViewModels"
             xmlns:models="using:Tranbok.Tools.Core.Models"
             xmlns:designer="using:Tranbok.Tools.Designer.Controls"
             x:Class="Tranbok.Tools.Plugin.PluginManager.Views.PluginManagerView"
             x:DataType="vm:PluginManagerViewModel">
  <designer:ToolPageLayout HeaderBodyGapHeight="0"
                           BodyFooterGapHeight="0"
                           FooterHeight="0">
    <designer:ToolPageLayout.BodyContent>
      <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                    VerticalScrollBarVisibility="Auto">
        <StackPanel Spacing="20">
          <TextBlock Classes="caption-muted"
                     Text="通过卡片中的启用开关和排序值，直接控制插件的挂载与卸载。"
                     TextWrapping="Wrap" />

          <ItemsControl ItemsSource="{Binding Plugins}">
            <ItemsControl.ItemsPanel>
              <ItemsPanelTemplate>
                <UniformGrid Columns="2" />
              </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
              <DataTemplate x:DataType="models:PluginEntry">
                <designer:PluginCard Title="{Binding Name}"
                                     Description="{Binding Description}"
                                     Margin="0,0,12,12">
                  <designer:PluginCard.HeaderContent>
                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center"
                                Spacing="6">
                      <designer:StatusBadge Text="{Binding BuiltInHint}"
                                            BadgeBackground="{DynamicResource TranbokBadgeWarningBackgroundBrush}"
                                            BadgeForeground="{DynamicResource TranbokBadgeWarningForegroundBrush}"
                                            IsVisible="{Binding IsBuiltIn}" />
                      <ItemsControl ItemsSource="{Binding DisplayTags}">
                        <ItemsControl.ItemsPanel>
                          <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal" Spacing="6" />
                          </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                          <DataTemplate>
                            <designer:StatusBadge Text="{Binding}"
                                                  BadgeBackground="{DynamicResource TranbokSurfaceElevatedBrush}"
                                                  BadgeForeground="{DynamicResource TranbokTextMutedBrush}" />
                          </DataTemplate>
                        </ItemsControl.ItemTemplate>
                      </ItemsControl>
                    </StackPanel>
                  </designer:PluginCard.HeaderContent>

                  <designer:PluginCard.DetailsContent>
                    <Grid ColumnDefinitions="92,*"
                          RowDefinitions="Auto,Auto"
                          RowSpacing="10"
                          ColumnSpacing="12">
                      <TextBlock Grid.Row="0" Classes="field-label" Text="插件 ID" />
                      <TextBlock Grid.Row="0" Grid.Column="1" Classes="field-value" Text="{Binding Id}" TextWrapping="Wrap" />

                      <TextBlock Grid.Row="1" Classes="field-label" Text="版本" />
                      <TextBlock Grid.Row="1" Grid.Column="1" Classes="field-value" Text="{Binding Version}" />
                    </Grid>
                  </designer:PluginCard.DetailsContent>

                  <designer:PluginCard.FooterContent>
                    <StackPanel Spacing="10">
                      <Grid ColumnDefinitions="Auto,8,Auto,*,Auto,8,88"
                            VerticalAlignment="Center">
                        <TextBlock Grid.Column="0"
                                   Text="启用"
                                   FontSize="14"
                                   VerticalAlignment="Center" />

                        <ToggleSwitch Grid.Column="2"
                                      VerticalAlignment="Center"
                                      IsChecked="{Binding IsEnabled, Mode=TwoWay}"
                                      IsEnabled="{Binding CanDisable}" />

                        <TextBlock Grid.Column="4"
                                   Text="排序"
                                   FontSize="14"
                                   VerticalAlignment="Center" />

                        <TextBox Grid.Column="6"
                                 Height="32"
                                 MinHeight="32"
                                 Padding="10,0"
                                 Text="{Binding Sort, Mode=TwoWay}"
                                 FontSize="14"
                                 HorizontalContentAlignment="Center"
                                 VerticalContentAlignment="Center"
                                 VerticalAlignment="Center" />
                      </Grid>

                      <TextBlock Classes="caption-muted"
                                 Text="排序值越小越靠前；关闭后插件将从导航中卸载。"
                                 TextWrapping="Wrap" />
                    </StackPanel>
                  </designer:PluginCard.FooterContent>
                </designer:PluginCard>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </StackPanel>
      </ScrollViewer>
    </designer:ToolPageLayout.BodyContent>
  </designer:ToolPageLayout>
</UserControl>
