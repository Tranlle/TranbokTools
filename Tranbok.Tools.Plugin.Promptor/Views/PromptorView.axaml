<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Tranbok.Tools.Plugin.Promptor.ViewModels"
             xmlns:designer="using:Tranbok.Tools.Designer.Controls"
             x:DataType="vm:PromptorViewModel"
             x:Class="Tranbok.Tools.Plugin.Promptor.Views.PromptorView">

  <UserControl.Styles>
    <!-- ComboBox 紧凑模式，用于 ActionBar 内联控件 -->
    <Style Selector="ComboBox.inline-compact">
      <Setter Property="Height" Value="34" />
      <Setter Property="MinHeight" Value="34" />
      <Setter Property="Padding" Value="10,0" />
      <Setter Property="FontSize" Value="13" />
      <Setter Property="VerticalAlignment" Value="Center" />
      <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>
  </UserControl.Styles>

  <!-- 无底部 Footer，只保留 Header + Body -->
  <designer:ToolPageLayout FooterHeight="0"
                           BodyFooterGapHeight="0">

    <!-- ═══ 操作栏 ════════════════════════════════════════════════════ -->
    <designer:ToolPageLayout.HeaderContent>
      <designer:ActionBar StatusText="{Binding StatusMessage}"
                          IsBusy="{Binding IsBusy}">

        <designer:ActionBar.LeadContent>
          <!-- 策略选择器 -->
          <StackPanel Orientation="Horizontal"
                      Spacing="8"
                      VerticalAlignment="Center">
            <TextBlock Text="优化策略"
                       FontSize="13"
                       Foreground="{DynamicResource TranbokTextSecondaryBrush}"
                       VerticalAlignment="Center" />
            <ComboBox Classes="inline-compact"
                      MinWidth="110"
                      ItemsSource="{Binding StrategyOptions}"
                      SelectedItem="{Binding SelectedStrategyOption, Mode=TwoWay}"
                      DisplayMemberBinding="{Binding Label}" />
            <TextBlock Text="{Binding StrategyDescription}"
                       FontSize="13"
                       Foreground="{DynamicResource TranbokTextMutedBrush}"
                       VerticalAlignment="Center" />
          </StackPanel>
        </designer:ActionBar.LeadContent>

        <designer:ActionBar.ActionsContent>
          <designer:ActionGroup>
            <designer:ActionGroup.Body>
              <StackPanel Orientation="Horizontal" Spacing="8">

                <Button Content="清空全部"
                        Command="{Binding ClearAllCommand}"
                        IsEnabled="{Binding IsIdle}" />

                <Button Content="查看日志"
                        Command="{Binding ShowLogCommand}" />

                <Button Content="{Binding CopyButtonText}"
                        Command="{Binding CopyCommand}"
                        IsEnabled="{Binding HasOptimizedOutput}" />

                <Button Content="取消"
                        Command="{Binding CancelCommand}"
                        IsVisible="{Binding IsBusy}" />

                <!-- 分隔线 -->
                <Border Width="1"
                        VerticalAlignment="Stretch"
                        Margin="4,8"
                        Background="{DynamicResource TranbokBorderBrush}" />

                <Button Classes="accent"
                        Content="优化提示词"
                        ToolTip.Tip="Ctrl+Enter"
                        Command="{Binding OptimizeCommand}"
                        IsEnabled="{Binding CanOptimize}" />

              </StackPanel>
            </designer:ActionGroup.Body>
          </designer:ActionGroup>
        </designer:ActionBar.ActionsContent>

      </designer:ActionBar>
    </designer:ToolPageLayout.HeaderContent>

    <!-- ═══ 主体工作区 ════════════════════════════════════════════════ -->
    <designer:ToolPageLayout.BodyContent>
      <designer:SplitWorkspace LeftWidth="480"
                               LeftMinWidth="300"
                               RightMinWidth="300">

        <!-- 左侧：原始提示词输入 -->
        <designer:SplitWorkspace.LeftContent>
          <designer:CardTextEditor
            Title="原始提示词"
            Description="输入需要优化的提示词原文，Ctrl+Enter 快速优化。"
            Text="{Binding RawInput, Mode=TwoWay}"
            PlaceholderText="在此输入需要优化的提示词内容…"
            AcceptsReturn="True"
            AcceptsTab="True"
            SubmitCommand="{Binding OptimizeCommand}" />
        </designer:SplitWorkspace.LeftContent>

        <!-- 右侧：优化结果输出 -->
        <designer:SplitWorkspace.RightContent>
          <designer:CardTextEditor
            Title="优化结果"
            Description="优化后的提示词将在此处流式显示。"
            Text="{Binding OptimizedOutput, Mode=TwoWay}"
            PlaceholderText="优化结果将在此处流式显示…"
            IsReadOnly="{Binding IsBusy}">
            <designer:CardTextEditor.ActionContent>
              <Button Content="清空"
                      Command="{Binding ClearOutputCommand}"
                      IsEnabled="{Binding HasOptimizedOutput}" />
            </designer:CardTextEditor.ActionContent>
          </designer:CardTextEditor>
        </designer:SplitWorkspace.RightContent>

      </designer:SplitWorkspace>
    </designer:ToolPageLayout.BodyContent>

  </designer:ToolPageLayout>
</UserControl>
