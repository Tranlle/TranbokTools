<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Tranbok.Tools.Plugin.Settings.ViewModels"
             xmlns:designer="using:Tranbok.Tools.Designer.Controls"
             xmlns:models="using:Tranbok.Tools.Designer.Models"
             x:Class="Tranbok.Tools.Plugin.Settings.Views.SettingsView"
             x:DataType="vm:SettingsViewModel">
  <designer:ToolPageLayout HeaderBodyGapHeight="0"
                           BodyFooterGapHeight="0"
                           FooterHeight="0">
    <designer:ToolPageLayout.BodyContent>
      <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                    VerticalScrollBarVisibility="Auto">
        <StackPanel Spacing="20">

          <!-- ═══ 主题设置 ═══════════════════════════════════════════════ -->
          <designer:SectionCard Title="主题设置"
                                Description="管理明暗切换、配色方案与全局字体。">
            <designer:SectionCard.Body>
              <Grid ColumnDefinitions="*,20,*"
                    RowDefinitions="Auto,Auto,Auto,Auto,Auto"
                    RowSpacing="16">
                <designer:FormField Grid.Row="0" Grid.Column="0" Label="应用名称">
                  <designer:FormField.Body>
                    <TextBox Classes="form-control"
                             Text="{Binding AppName, Mode=TwoWay}"
                             PlaceholderText="应用名称" />
                  </designer:FormField.Body>
                </designer:FormField>

                <designer:FormField Grid.Row="0" Grid.Column="2" Label="主题模式">
                  <designer:FormField.Body>
                    <ComboBox Classes="form-control"
                              ItemsSource="{Binding ThemeOptions}"
                              SelectedItem="{Binding SelectedThemeOption, Mode=TwoWay}"
                              DisplayMemberBinding="{Binding Label}" />
                  </designer:FormField.Body>
                </designer:FormField>

                <designer:FormField Grid.Row="1" Grid.ColumnSpan="3"
                                    Label="内置配色方案"
                                    Description="{Binding SelectedPaletteOption.Description}">
                  <designer:FormField.Body>
                    <ComboBox Classes="form-control"
                              ItemsSource="{Binding PaletteOptions}"
                              SelectedItem="{Binding SelectedPaletteOption, Mode=TwoWay}"
                              DisplayMemberBinding="{Binding Label}" />
                  </designer:FormField.Body>
                </designer:FormField>

                <designer:FormField Grid.Row="2" Grid.ColumnSpan="3"
                                    Label="全局字体"
                                    Description="{Binding SelectedFontOption.Description}">
                  <designer:FormField.Body>
                    <ComboBox Classes="form-control"
                              ItemsSource="{Binding FontOptions}"
                              SelectedItem="{Binding SelectedFontOption, Mode=TwoWay}"
                              DisplayMemberBinding="{Binding Label}" />
                  </designer:FormField.Body>
                </designer:FormField>

                <Border Grid.Row="3"
                        Grid.ColumnSpan="3"
                        IsVisible="{Binding IsInterFontWarningVisible}"
                        Background="{DynamicResource TranbokBadgeWarningBackgroundBrush}"
                        BorderBrush="{DynamicResource TranbokBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="{DynamicResource TranbokRadiusSmall}"
                        Padding="12,10">
                  <TextBlock Text="{Binding FontWarningMessage}"
                             Foreground="{DynamicResource TranbokBadgeWarningForegroundBrush}"
                             TextWrapping="Wrap" />
                </Border>

                <CheckBox Grid.Row="4" Grid.ColumnSpan="3"
                          Content="迁移默认启用 Workspace 模式"
                          IsChecked="{Binding UseWorkspaceForMigrations, Mode=TwoWay}" />
              </Grid>
            </designer:SectionCard.Body>
          </designer:SectionCard>

          <!-- ═══ 高级主题 ════════════════════════════════════════════════ -->
          <designer:SectionCard Title="高级主题"
                                Description="自定义 palette 扩展入口。">
            <designer:SectionCard.Body>
              <StackPanel Spacing="16">
                <CheckBox Content="显示高级主题设置"
                          IsChecked="{Binding ShowAdvancedThemeSettings, Mode=TwoWay}" />

                <StackPanel Spacing="16" IsVisible="{Binding ShowAdvancedThemeSettings}">
                  <designer:FormField Label="高级主题方案"
                                      Description="{Binding SelectedAdvancedPaletteOption.Description}">
                    <designer:FormField.Body>
                      <ComboBox Classes="form-control"
                                ItemsSource="{Binding AdvancedPaletteOptions}"
                                SelectedItem="{Binding SelectedAdvancedPaletteOption, Mode=TwoWay}"
                                DisplayMemberBinding="{Binding Label}" />
                    </designer:FormField.Body>
                  </designer:FormField>

                  <designer:FormField Label="自定义主题目录">
                    <designer:FormField.Body>
                      <TextBox Classes="form-control"
                               Text="{Binding CustomThemeDirectory, Mode=TwoWay}" />
                    </designer:FormField.Body>
                  </designer:FormField>
                </StackPanel>
              </StackPanel>
            </designer:SectionCard.Body>
          </designer:SectionCard>

          <!-- ═══ 工作区 ════════════════════════════════════════════════ -->
          <designer:SectionCard Title="工作区"
                                Description="配置当前工具宿主的工作区路径。">
            <designer:SectionCard.Body>
              <designer:FormField Label="工作区路径">
                <designer:FormField.Body>
                  <TextBox Classes="form-control"
                           Text="{Binding WorkspaceRoot, Mode=TwoWay}" />
                </designer:FormField.Body>
              </designer:FormField>
            </designer:SectionCard.Body>
          </designer:SectionCard>

          <!-- ═══ 插件变量管理 ══════════════════════════════════════════ -->
          <designer:SectionCard Title="插件变量管理"
                                Description="集中配置各插件所需的环境变量键值对，保存时写入持久化存储，由各插件自行读取与校验。">
            <designer:SectionCard.Body>
              <StackPanel Spacing="12">

                <!-- 工具栏：摘要 + 新建按钮 -->
                <Grid ColumnDefinitions="*,Auto">
                  <TextBlock Grid.Column="0"
                             Classes="caption-muted"
                             VerticalAlignment="Center"
                             Text="{Binding PluginVariableSummary}" />
                  <Button Grid.Column="1"
                          Command="{Binding ShowAddVariableFormCommand}"
                          IsVisible="{Binding !ShowAddVariableForm}"
                          Classes="accent"
                          Content="新建变量" />
                </Grid>

                <!-- 新建变量面板 -->
                <Border IsVisible="{Binding ShowAddVariableForm}"
                        Background="{DynamicResource TranbokSurfaceElevatedBrush}"
                        BorderBrush="{DynamicResource TranbokAccentBrush}"
                        BorderThickness="1"
                        CornerRadius="{DynamicResource TranbokRadiusMedium}"
                        Padding="16">
                  <StackPanel Spacing="14">

                    <TextBlock Classes="subsection-title" Text="新建插件变量" />

                    <Grid ColumnDefinitions="*,16,*" RowSpacing="12">
                      <designer:FormField Grid.Column="0" Label="所属插件">
                        <designer:FormField.Body>
                          <ComboBox Classes="form-control"
                                    ItemsSource="{Binding PluginOptions}"
                                    SelectedItem="{Binding AddFormSelectedPlugin, Mode=TwoWay}"
                                    DisplayMemberBinding="{Binding Label}" />
                        </designer:FormField.Body>
                      </designer:FormField>

                      <designer:FormField Grid.Column="2" Label="变量键">
                        <designer:FormField.Body>
                          <TextBox Classes="form-control"
                                   Text="{Binding AddFormKey, Mode=TwoWay}"
                                   PlaceholderText="例如：MY_API_KEY" />
                        </designer:FormField.Body>
                      </designer:FormField>
                    </Grid>

                    <!-- 快速填入：来自插件声明的变量键 -->
                    <StackPanel Spacing="6"
                                IsVisible="{Binding HasAddFormKeyHints}">
                      <TextBlock Classes="caption-muted"
                                 Text="插件已声明的变量键（点击快速填入）：" />
                      <ItemsControl ItemsSource="{Binding AddFormKeyHints}">
                        <ItemsControl.ItemsPanel>
                          <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal" />
                          </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                          <DataTemplate x:DataType="models:DesignerOptionItem">
                            <Button Command="{Binding $parent[UserControl].((vm:SettingsViewModel)DataContext).FillKeyFromHintCommand}"
                                    CommandParameter="{Binding}"
                                    Height="28"
                                    MinHeight="28"
                                    Padding="10,0"
                                    Margin="0,0,6,6"
                                    FontSize="12"
                                    ToolTip.Tip="{Binding Description}">
                              <TextBlock Text="{Binding Label}" FontSize="12" />
                            </Button>
                          </DataTemplate>
                        </ItemsControl.ItemTemplate>
                      </ItemsControl>
                    </StackPanel>

                    <designer:FormField Label="变量值">
                      <designer:FormField.Body>
                        <TextBox Classes="form-control"
                                 Text="{Binding AddFormValue, Mode=TwoWay}"
                                 PlaceholderText="输入该变量的值" />
                      </designer:FormField.Body>
                    </designer:FormField>

                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Right"
                                Spacing="8">
                      <Button Command="{Binding CancelAddVariableCommand}"
                              Content="取消" />
                      <Button Command="{Binding AddVariableCommand}"
                              Classes="accent"
                              Content="添加" />
                    </StackPanel>
                  </StackPanel>
                </Border>

                <!-- 已有变量列表 -->
                <StackPanel Spacing="0"
                            IsVisible="{Binding HasPluginVariables}">

                  <!-- 列表表头 -->
                  <Grid ColumnDefinitions="140,*,180,36"
                        ColumnSpacing="8"
                        Margin="4,0,4,6">
                    <TextBlock Grid.Column="0" Classes="field-label" Text="插件" />
                    <TextBlock Grid.Column="1" Classes="field-label" Text="变量键" />
                    <TextBlock Grid.Column="2" Classes="field-label" Text="当前值" />
                  </Grid>

                  <Border BorderBrush="{DynamicResource TranbokBorderBrush}"
                          BorderThickness="0,1,0,0" />

                  <ItemsControl ItemsSource="{Binding PluginVariableItems}">
                    <ItemsControl.ItemTemplate>
                      <DataTemplate x:DataType="vm:PluginVariableItemViewModel">
                        <Border BorderBrush="{DynamicResource TranbokBorderBrush}"
                                BorderThickness="0,0,0,1"
                                Padding="4,8">
                          <Grid ColumnDefinitions="140,*,180,36"
                                ColumnSpacing="8"
                                VerticalAlignment="Center">

                            <!-- 插件名 -->
                            <TextBlock Grid.Column="0"
                                       Text="{Binding PluginName}"
                                       Classes="field-value"
                                       FontSize="13"
                                       TextTrimming="CharacterEllipsis"
                                       VerticalAlignment="Center" />

                            <!-- 键名 + 说明 -->
                            <StackPanel Grid.Column="1"
                                        Spacing="2"
                                        VerticalAlignment="Center">
                              <TextBlock Text="{Binding Key}"
                                         FontFamily="{DynamicResource TranbokMonoFontFamily}"
                                         FontSize="13" />
                              <TextBlock Text="{Binding Description}"
                                         Classes="caption-muted"
                                         IsVisible="{Binding IsFromMetadata}"
                                         TextWrapping="Wrap" />
                            </StackPanel>

                            <!-- 可编辑值 -->
                            <TextBox Grid.Column="2"
                                     Classes="form-control"
                                     Text="{Binding Value, Mode=TwoWay}"
                                     Height="32"
                                     MinHeight="32"
                                     VerticalAlignment="Center" />

                            <!-- 删除按钮 -->
                            <Button Grid.Column="3"
                                    Command="{Binding DeleteCommand}"
                                    Classes="danger"
                                    Width="32"
                                    Height="32"
                                    MinHeight="32"
                                    Padding="0"
                                    VerticalAlignment="Center"
                                    HorizontalAlignment="Center"
                                    ToolTip.Tip="删除此变量"
                                    Content="×" />
                          </Grid>
                        </Border>
                      </DataTemplate>
                    </ItemsControl.ItemTemplate>
                  </ItemsControl>
                </StackPanel>

                <!-- 空状态提示 -->
                <TextBlock Classes="caption-muted"
                           IsVisible="{Binding !HasPluginVariables}"
                           Text="暂无已配置的插件变量。点击「新建变量」添加第一条。" />

              </StackPanel>
            </designer:SectionCard.Body>
          </designer:SectionCard>

        </StackPanel>
      </ScrollViewer>
    </designer:ToolPageLayout.BodyContent>
  </designer:ToolPageLayout>
</UserControl>
