<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Tranbok.Tools.Plugin.Settings.ViewModels"
             xmlns:designer="using:Tranbok.Tools.Designer.Controls"
             x:Class="Tranbok.Tools.Plugin.Settings.Views.SettingsView"
             x:DataType="vm:SettingsViewModel">
  <designer:ToolPageLayout HeaderBodyGapHeight="0"
                           BodyFooterGapHeight="0"
                           FooterHeight="0">
    <designer:ToolPageLayout.BodyContent>
      <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                    VerticalScrollBarVisibility="Auto">
        <StackPanel Spacing="20">

          <designer:SectionCard Title="主题设置"
                                Description="管理明暗切换、配色方案与全局字体。">
            <designer:SectionCard.Body>
              <Grid ColumnDefinitions="*,20,*"
                    RowDefinitions="Auto,Auto,Auto,Auto,Auto"
                    RowSpacing="16">
                <designer:FormField Grid.Row="0" Grid.Column="0" Label="应用名称">
                  <designer:FormField.Body>
                    <TextBox Classes="form-control"
                             Text="{Binding AppName, Mode=TwoWay}"
                             PlaceholderText="应用名称" />
                  </designer:FormField.Body>
                </designer:FormField>

                <designer:FormField Grid.Row="0" Grid.Column="2" Label="主题模式">
                  <designer:FormField.Body>
                    <ComboBox Classes="form-control"
                              ItemsSource="{Binding ThemeOptions}"
                              SelectedItem="{Binding SelectedThemeOption, Mode=TwoWay}"
                              DisplayMemberBinding="{Binding Label}" />
                  </designer:FormField.Body>
                </designer:FormField>

                <designer:FormField Grid.Row="1" Grid.ColumnSpan="3"
                                    Label="内置配色方案"
                                    Description="{Binding SelectedPaletteOption.Description}">
                  <designer:FormField.Body>
                    <ComboBox Classes="form-control"
                              ItemsSource="{Binding PaletteOptions}"
                              SelectedItem="{Binding SelectedPaletteOption, Mode=TwoWay}"
                              DisplayMemberBinding="{Binding Label}" />
                  </designer:FormField.Body>
                </designer:FormField>

                <designer:FormField Grid.Row="2" Grid.ColumnSpan="3"
                                    Label="全局字体"
                                    Description="{Binding SelectedFontOption.Description}">
                  <designer:FormField.Body>
                    <ComboBox Classes="form-control"
                              ItemsSource="{Binding FontOptions}"
                              SelectedItem="{Binding SelectedFontOption, Mode=TwoWay}"
                              DisplayMemberBinding="{Binding Label}" />
                  </designer:FormField.Body>
                </designer:FormField>

                <Border Grid.Row="3"
                        Grid.ColumnSpan="3"
                        IsVisible="{Binding IsInterFontWarningVisible}"
                        Background="{DynamicResource TranbokBadgeWarningBackgroundBrush}"
                        BorderBrush="{DynamicResource TranbokBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="{DynamicResource TranbokRadiusSmall}"
                        Padding="12,10">
                  <TextBlock Text="{Binding FontWarningMessage}"
                             Foreground="{DynamicResource TranbokBadgeWarningForegroundBrush}"
                             TextWrapping="Wrap" />
                </Border>

                <CheckBox Grid.Row="4" Grid.ColumnSpan="3"
                          Content="迁移默认启用 Workspace 模式"
                          IsChecked="{Binding UseWorkspaceForMigrations, Mode=TwoWay}" />
              </Grid>
            </designer:SectionCard.Body>
          </designer:SectionCard>

          <designer:SectionCard Title="高级主题"
                                Description="自定义 palette 扩展入口。">
            <designer:SectionCard.Body>
              <StackPanel Spacing="16">
                <CheckBox Content="显示高级主题设置"
                          IsChecked="{Binding ShowAdvancedThemeSettings, Mode=TwoWay}" />

                <StackPanel Spacing="16" IsVisible="{Binding ShowAdvancedThemeSettings}">
                  <designer:FormField Label="高级主题方案"
                                      Description="{Binding SelectedAdvancedPaletteOption.Description}">
                    <designer:FormField.Body>
                      <ComboBox Classes="form-control"
                                ItemsSource="{Binding AdvancedPaletteOptions}"
                                SelectedItem="{Binding SelectedAdvancedPaletteOption, Mode=TwoWay}"
                                DisplayMemberBinding="{Binding Label}" />
                    </designer:FormField.Body>
                  </designer:FormField>

                  <designer:FormField Label="自定义主题目录">
                    <designer:FormField.Body>
                      <TextBox Classes="form-control"
                               Text="{Binding CustomThemeDirectory, Mode=TwoWay}" />
                    </designer:FormField.Body>
                  </designer:FormField>
                </StackPanel>
              </StackPanel>
            </designer:SectionCard.Body>
          </designer:SectionCard>

          <designer:SectionCard Title="工作区"
                                Description="配置当前工具宿主的工作区路径。">
            <designer:SectionCard.Body>
              <designer:FormField Label="工作区路径">
                <designer:FormField.Body>
                  <TextBox Classes="form-control"
                           Text="{Binding WorkspaceRoot, Mode=TwoWay}" />
                </designer:FormField.Body>
              </designer:FormField>
            </designer:SectionCard.Body>
          </designer:SectionCard>

        </StackPanel>
      </ScrollViewer>
    </designer:ToolPageLayout.BodyContent>
  </designer:ToolPageLayout>
</UserControl>
