<UserControl x:Class="Tranbok.Tools.Plugins.Migration.Views.MigrationView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:Tranbok.Tools.Plugins.Migration.ViewModels"
             xmlns:models="clr-namespace:Tranbok.Tools.Plugins.Migration.Models"
             mc:Ignorable="d"
             Background="{StaticResource BgCanvasBrush}"
             d:DataContext="{d:DesignInstance vm:MigrationViewModel}">

    <UserControl.Resources>
        <Style x:Key="SectionLabel" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="{StaticResource SansFont}"/>
            <Setter Property="FontSize" Value="10.5"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource FgSubtleBrush}"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="98"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="190"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="{StaticResource BgDefaultBrush}"
                BorderBrush="{StaticResource BorderMutedBrush}"
                BorderThickness="0,0,0,1"
                Padding="20,10,20,12">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="60"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="140"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="&#xE1D3;"
                                   FontFamily="Segoe MDL2 Assets"
                                   FontSize="18"
                                   Foreground="{StaticResource AccentBlueBrush}"
                                   VerticalAlignment="Center"
                                   Margin="0,0,10,0"/>
                        <TextBlock Text="数据库迁移"
                                   FontSize="18"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource FgDefaultBrush}"
                                   VerticalAlignment="Center"/>
                        <Border Background="{StaticResource SelectionBgBrush}"
                                BorderBrush="{StaticResource AccentBlueBrush}"
                                BorderThickness="1"
                                CornerRadius="4"
                                Padding="8,3"
                                Margin="12,0,0,0"
                                VerticalAlignment="Center">
                            <TextBlock Text="{Binding ActiveProfile.DisplayName}"
                                       Foreground="{StaticResource AccentBlueBrush}"
                                       FontSize="11"
                                       FontWeight="SemiBold"/>
                        </Border>
                    </StackPanel>

                    <ProgressBar Grid.Column="1"
                                 Width="120"
                                 Height="4"
                                 HorizontalAlignment="Right"
                                 VerticalAlignment="Center"
                                 IsIndeterminate="True"
                                 Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}"/>
                </Grid>

                <Border Grid.Row="1" Height="48" Background="Transparent">
                    <ScrollViewer HorizontalScrollBarVisibility="Auto"
                                  VerticalScrollBarVisibility="Disabled"
                                  CanContentScroll="False">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Button Command="{Binding AddProfileCommand}"
                                    Style="{StaticResource PrimaryButton}"
                                    MinWidth="112"
                                    BorderThickness="1"
                                    BorderBrush="{StaticResource AccentBlueBrush}"
                                    Margin="0,0,8,0"
                                    VerticalContentAlignment="Center">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Text="&#xE710;" FontFamily="Segoe MDL2 Assets" FontSize="11" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                    <TextBlock Text="新增配置" FontSize="11" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <Button Command="{Binding DeleteProfileCommand}"
                                    Style="{StaticResource DangerButton}"
                                    MinWidth="112"
                                    BorderThickness="1"
                                    BorderBrush="{StaticResource AccentRedBrush}"
                                    Margin="0,0,8,0"
                                    VerticalContentAlignment="Center">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Text="&#xE74D;" FontFamily="Segoe MDL2 Assets" FontSize="11" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                    <TextBlock Text="删除配置" FontSize="11" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <Button Command="{Binding OpenEditProfileCommand}"
                                    Style="{StaticResource GhostButton}"
                                    MinWidth="112"
                                    BorderThickness="1"
                                    BorderBrush="{StaticResource BorderMutedBrush}"
                                    Margin="0,0,8,0"
                                    VerticalContentAlignment="Center">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Text="&#xE70F;" FontFamily="Segoe MDL2 Assets" FontSize="11" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                    <TextBlock Text="修改配置" FontSize="11" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <Button Command="{Binding RefreshCommand}"
                                    Style="{StaticResource GhostButton}"
                                    MinWidth="112"
                                    BorderThickness="1"
                                    BorderBrush="{StaticResource BorderMutedBrush}"
                                    Margin="0,0,8,0"
                                    VerticalContentAlignment="Center">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Text="&#xE72C;" FontFamily="Segoe MDL2 Assets" FontSize="11" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                    <TextBlock Text="刷新迁移" FontSize="11" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <Button Command="{Binding ExecuteUpdateCommand}"
                                    Style="{StaticResource SuccessButton}"
                                    IsEnabled="{Binding IsIdle}"
                                    MinWidth="112"
                                    BorderThickness="1"
                                    BorderBrush="{StaticResource AccentGreenBrush}"
                                    Margin="0,0,8,0"
                                    VerticalContentAlignment="Center">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Text="&#xE768;" FontFamily="Segoe MDL2 Assets" FontSize="11" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                    <TextBlock Text="执行更新" FontSize="11" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <Button Command="{Binding ShowNewPanelCommand}"
                                    Style="{StaticResource GhostButton}"
                                    MinWidth="112"
                                    BorderThickness="1"
                                    BorderBrush="{StaticResource BorderMutedBrush}"
                                    Margin="0,0,8,0"
                                    VerticalContentAlignment="Center">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Text="&#xE8B7;" FontFamily="Segoe MDL2 Assets" FontSize="11" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                    <TextBlock Text="新增迁移" FontSize="11" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <Button Command="{Binding RollbackSelectedCommand}"
                                    Style="{StaticResource GhostButton}"
                                    IsEnabled="{Binding CanRollback}"
                                    MinWidth="112"
                                    BorderThickness="1"
                                    BorderBrush="{StaticResource BorderMutedBrush}"
                                    VerticalContentAlignment="Center">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Text="&#xE7A7;" FontFamily="Segoe MDL2 Assets" FontSize="11" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                    <TextBlock Text="删除迁移" FontSize="11" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </ScrollViewer>
                </Border>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="320"/>
                <ColumnDefinition Width="6"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Background="{StaticResource BgDefaultBrush}"
                    BorderBrush="{StaticResource BorderMutedBrush}"
                    BorderThickness="0,0,1,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="44"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0"
                            BorderBrush="{StaticResource BorderMutedBrush}"
                            BorderThickness="0,0,0,1"
                            Padding="14,0">
                        <TextBlock Text="配置列表"
                                   Style="{StaticResource SectionLabel}"
                                   Margin="0"
                                   VerticalAlignment="Center"/>
                    </Border>

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding DbProfiles}" Margin="8,8">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type models:DbConnectionProfile}">
                                    <Border x:Name="profileItem"
                                            CornerRadius="6"
                                            Padding="12,10"
                                            Margin="0,0,0,6"
                                            Background="Transparent"
                                            BorderBrush="Transparent"
                                            BorderThickness="1"
                                            Cursor="Hand">
                                        <Border.InputBindings>
                                            <MouseBinding MouseAction="LeftClick"
                                                          Command="{Binding DataContext.SelectProfileCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                          CommandParameter="{Binding}"/>
                                        </Border.InputBindings>
                                        <StackPanel>
                                            <TextBlock Text="{Binding ProfileName}"
                                                       FontSize="13"
                                                       FontWeight="SemiBold"
                                                       Foreground="{StaticResource FgDefaultBrush}"/>
                                            <TextBlock Text="{Binding DisplayName}"
                                                       Margin="0,4,0,0"
                                                       FontSize="11"
                                                       Foreground="{StaticResource FgSubtleBrush}"/>
                                            <TextBlock Text="{Binding ContextName}"
                                                       Margin="0,2,0,0"
                                                       FontSize="11"
                                                       Foreground="{StaticResource FgSubtleBrush}"
                                                       TextTrimming="CharacterEllipsis"/>
                                        </StackPanel>
                                    </Border>
                                    <DataTemplate.Triggers>
                                        <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                            <Setter TargetName="profileItem" Property="Background" Value="{StaticResource SelectionBgBrush}"/>
                                            <Setter TargetName="profileItem" Property="BorderBrush" Value="{StaticResource AccentBlueBrush}"/>
                                        </DataTrigger>
                                    </DataTemplate.Triggers>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>

            <GridSplitter Grid.Column="1" HorizontalAlignment="Stretch" Background="{StaticResource BorderMutedBrush}"/>

            <Grid Grid.Column="2" Background="{StaticResource BgCanvasBrush}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0"
                        Background="{StaticResource BgDefaultBrush}"
                        BorderBrush="{StaticResource BorderMutedBrush}"
                        BorderThickness="0,0,0,1"
                        Padding="18,12">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
                            <TextBlock Text="数据库类型" Style="{StaticResource TextLabel}" Margin="0,0,10,0" VerticalAlignment="Center"/>
                            <ItemsControl ItemsSource="{Binding OrderedProfiles}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Orientation="Horizontal"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate DataType="{x:Type models:DbConnectionProfile}">
                                        <Border x:Name="profileTypeBadge"
                                                Margin="0,0,12,0"
                                                Padding="12,6"
                                                CornerRadius="6"
                                                BorderThickness="1"
                                                Background="{StaticResource BgOverlayBrush}"
                                                BorderBrush="{StaticResource BorderMutedBrush}">
                                            <TextBlock Text="{Binding DisplayName}"
                                                       Foreground="{StaticResource FgDefaultBrush}"/>
                                        </Border>
                                        <DataTemplate.Triggers>
                                            <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                <Setter TargetName="profileTypeBadge" Property="BorderBrush" Value="{StaticResource FgSubtleBrush}"/>
                                            </DataTrigger>
                                        </DataTemplate.Triggers>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>

                        <TextBlock Grid.Row="1"
                                   Text="{Binding OutputDirectory, StringFormat='复制目标目录：{0}'}"
                                   Foreground="{StaticResource FgSubtleBrush}"
                                   FontSize="11"
                                   TextWrapping="Wrap"/>
                    </Grid>
                </Border>

                <Border Grid.Row="1"
                        Background="{StaticResource BgDefaultBrush}"
                        BorderBrush="{StaticResource BorderMutedBrush}"
                        BorderThickness="0,0,0,1"
                        Padding="18,12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="迁移文件"
                                   Style="{StaticResource TextLabel}"
                                   Margin="0,0,10,0"
                                   VerticalAlignment="Center"/>
                        <ComboBox Grid.Column="1"
                                  ItemsSource="{Binding Migrations}"
                                  SelectedItem="{Binding SelectedMigration, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                  DisplayMemberPath="FullName"
                                  MinWidth="280"
                                  HorizontalContentAlignment="Stretch"
                                  Margin="0,0,12,0"/>
                        <Button Grid.Column="2"
                                Command="{Binding SaveEditorCommand}"
                                Style="{StaticResource PrimaryButton}"
                                IsEnabled="{Binding IsEditorDirty}">
                            <TextBlock Text="保存文件"/>
                        </Button>
                    </Grid>
                </Border>

                <Grid Grid.Row="2">
                    <TextBox Style="{StaticResource CodeTextBox}"
                             Text="{Binding EditorContent, UpdateSourceTrigger=PropertyChanged}"
                             IsEnabled="{Binding HasSelectedMigration, Mode=OneWay}"
                             Padding="16,12"
                             VerticalScrollBarVisibility="Auto"
                             HorizontalScrollBarVisibility="Auto"
                             AcceptsReturn="True"
                             AcceptsTab="True"
                             TextWrapping="NoWrap">
                        <TextBox.InputBindings>
                            <KeyBinding Gesture="Ctrl+S" Command="{Binding SaveEditorCommand}"/>
                        </TextBox.InputBindings>
                    </TextBox>

                    <StackPanel VerticalAlignment="Center"
                                HorizontalAlignment="Center"
                                Opacity="0.32"
                                IsHitTestVisible="False"
                                Visibility="{Binding HasSelectedMigration, Mode=OneWay, Converter={StaticResource InverseBoolToVisConverter}}">
                        <TextBlock Text="&#xE8A5;"
                                   FontFamily="Segoe MDL2 Assets"
                                   FontSize="44"
                                   HorizontalAlignment="Center"
                                   Foreground="{StaticResource FgSubtleBrush}"
                                   Margin="0,0,0,14"/>
                        <TextBlock Text="当前配置没有迁移，或请先从下拉框选择迁移"
                                   FontSize="13"
                                   Foreground="{StaticResource FgSubtleBrush}"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>
                </Grid>
            </Grid>
        </Grid>

        <Border Grid.RowSpan="3"
                Background="#80000000"
                Visibility="{Binding ShowNewMigrationPanel, Converter={StaticResource BoolToVis}}"
                Panel.ZIndex="20">
            <Grid>
                <Border Width="560"
                        Padding="24"
                        CornerRadius="10"
                        Background="{StaticResource BgDefaultBrush}"
                        BorderBrush="{StaticResource BorderMutedBrush}"
                        BorderThickness="1"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Text="新增迁移"
                                   FontSize="18"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource FgDefaultBrush}"
                                   Margin="0,0,0,18"/>

                        <Grid Grid.Row="1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="96"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="目标项目" Style="{StaticResource TextLabel}" Margin="0,0,12,10" VerticalAlignment="Center"/>
                            <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding ProjectPath}" Foreground="{StaticResource FgSubtleBrush}" TextTrimming="CharacterEllipsis" Margin="0,0,0,10"/>

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="目标数据库" Style="{StaticResource TextLabel}" Margin="0,0,12,10" VerticalAlignment="Center"/>
                            <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding ActiveProfile.DisplayName}" Foreground="{StaticResource FgDefaultBrush}" Margin="0,0,0,10"/>

                            <TextBlock Grid.Row="2" Grid.Column="0" Text="DbContext" Style="{StaticResource TextLabel}" Margin="0,0,12,10" VerticalAlignment="Center"/>
                            <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding ActiveProfile.ContextName}" Foreground="{StaticResource FgDefaultBrush}" Margin="0,0,0,10"/>

                            <TextBlock Grid.Row="3" Grid.Column="0" Text="迁移名称" Style="{StaticResource TextLabel}" Margin="0,0,12,0" VerticalAlignment="Center"/>
                            <TextBox Grid.Row="3" Grid.Column="1"
                                     Text="{Binding NewMigrationName, UpdateSourceTrigger=PropertyChanged}"
                                     MinWidth="360"/>
                        </Grid>

                        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,22,0,0">
                            <Button Content="取消" Command="{Binding CancelNewMigrationCommand}" Margin="0,0,8,0" MinWidth="88"/>
                            <Button Content="确认生成" Command="{Binding ConfirmAddMigrationCommand}" Style="{StaticResource PrimaryButton}" MinWidth="100"/>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
        </Border>

        <Border Grid.RowSpan="3"
                Background="#80000000"
                Visibility="{Binding ShowPromptDialog, Converter={StaticResource BoolToVis}}"
                Panel.ZIndex="30">
            <Grid>
                <Border Width="560"
                        Padding="24"
                        CornerRadius="10"
                        Background="{StaticResource BgDefaultBrush}"
                        BorderBrush="{StaticResource BorderMutedBrush}"
                        BorderThickness="1"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Text="{Binding PromptTitle}"
                                   FontSize="18"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource FgDefaultBrush}"
                                   Margin="0,0,0,16"/>

                        <TextBlock Grid.Row="1"
                                   Text="{Binding PromptMessage}"
                                   Foreground="{StaticResource FgSubtleBrush}"
                                   TextWrapping="Wrap"
                                   LineHeight="20"/>

                        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,22,0,0">
                            <Button Content="取消"
                                    Command="{Binding CancelPromptCommand}"
                                    Margin="0,0,8,0"
                                    MinWidth="88"
                                    Visibility="{Binding ShowPromptCancel, Converter={StaticResource BoolToVis}}"/>
                            <Button Content="{Binding PromptConfirmText}"
                                    Command="{Binding ConfirmPromptCommand}"
                                    Style="{StaticResource PrimaryButton}"
                                    MinWidth="100"/>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
        </Border>

        <Border Grid.RowSpan="3"
                Background="#80000000"
                Visibility="{Binding ShowEditProfileDialog, Converter={StaticResource BoolToVis}}"
                Panel.ZIndex="20">
            <Grid>
                <Border Width="860"
                        Height="620"
                        Padding="24"
                        CornerRadius="10"
                        Background="{StaticResource BgDefaultBrush}"
                        BorderBrush="{StaticResource BorderMutedBrush}"
                        BorderThickness="1"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Text="修改配置"
                                   FontSize="18"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource FgDefaultBrush}"
                                   Margin="0,0,0,18"/>

                        <Grid Grid.Row="1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="配置名称" Style="{StaticResource TextLabel}" Margin="0,0,12,10" VerticalAlignment="Center"/>
                            <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding EditingProfile.ProfileName, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,10"/>

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Domain 项目" Style="{StaticResource TextLabel}" Margin="0,0,12,10" VerticalAlignment="Center"/>
                            <DockPanel Grid.Row="1" Grid.Column="1" Margin="0,0,0,10">
                                <Button DockPanel.Dock="Right" Content="浏览" Width="56" Margin="8,0,0,0" Command="{Binding BrowseEditingProjectCommand}"/>
                                <TextBox Text="{Binding EditingProjectPath, UpdateSourceTrigger=PropertyChanged}"/>
                            </DockPanel>

                            <TextBlock Grid.Row="2" Grid.Column="0" Text="数据库类型" Style="{StaticResource TextLabel}" Margin="0,0,12,10" VerticalAlignment="Center"/>
                            <ComboBox Grid.Row="2" Grid.Column="1" SelectedValue="{Binding EditingProfile.DbType, Mode=TwoWay}" SelectedValuePath="Tag" Margin="0,0,0,10">
                                <ComboBoxItem Content="SQL Server" Tag="{x:Static models:DbType.SqlServer}"/>
                                <ComboBoxItem Content="PostgreSQL" Tag="{x:Static models:DbType.PostgreSQL}"/>
                                <ComboBoxItem Content="MySQL" Tag="{x:Static models:DbType.MySQL}"/>
                            </ComboBox>

                            <TextBlock Grid.Row="3" Grid.Column="0" Text="DbContext" Style="{StaticResource TextLabel}" Margin="0,0,12,10" VerticalAlignment="Center"/>
                            <TextBox Grid.Row="3" Grid.Column="1" Text="{Binding EditingProfile.ContextName, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,10"/>

                            <TextBlock Grid.Row="4" Grid.Column="0" Text="Workspace" Style="{StaticResource TextLabel}" Margin="0,0,12,10" VerticalAlignment="Center"/>
                            <CheckBox Grid.Row="4" Grid.Column="1"
                                      Content="启用 Workspace 模式"
                                      IsChecked="{Binding EditingProfile.UseWorkspace, Mode=TwoWay}"
                                      Margin="0,0,0,10"/>

                            <TextBlock Grid.Row="5" Grid.Column="0" Text="连接串" Style="{StaticResource TextLabel}" Margin="0,0,12,0" VerticalAlignment="Top"/>
                            <TextBox Grid.Row="5" Grid.Column="1"
                                     Text="{Binding EditingProfile.ConnectionString, UpdateSourceTrigger=PropertyChanged}"
                                     AcceptsReturn="True"
                                     TextWrapping="Wrap"
                                     VerticalScrollBarVisibility="Auto"
                                     MinHeight="220"/>
                        </Grid>

                        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,18,0,0">
                            <Button Content="取消" Command="{Binding CancelEditProfileCommand}" Margin="0,0,8,0" MinWidth="88"/>
                            <Button Content="确认修改" Command="{Binding ConfirmEditProfileCommand}" Style="{StaticResource PrimaryButton}" MinWidth="100"/>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
        </Border>

        <Border Grid.Row="2"
                Background="{StaticResource BgCanvasBrush}"
                BorderBrush="{StaticResource BorderMutedBrush}"
                BorderThickness="0,1,0,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="32"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="30"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0"
                        Background="{StaticResource BgDefaultBrush}"
                        BorderBrush="{StaticResource BorderMutedBrush}"
                        BorderThickness="0,0,0,1"
                        Padding="14,0">
                    <Grid VerticalAlignment="Center">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="日志 / 状态区"
                                   Style="{StaticResource SectionLabel}"
                                   Margin="0"
                                   VerticalAlignment="Center"/>
                        <Button Grid.Column="1"
                                Command="{Binding ClearLogCommand}"
                                Style="{StaticResource GhostButton}"
                                Height="22"
                                Padding="8,0"
                                FontSize="11">
                            <TextBlock Text="清除" Foreground="{StaticResource FgSubtleBrush}"/>
                        </Button>
                    </Grid>
                </Border>

                <TextBox Grid.Row="1"
                         x:Name="LogTextBox"
                         Text="{Binding OutputLog}"
                         FontFamily="Cascadia Code,Consolas"
                         FontSize="11.5"
                         Foreground="{StaticResource FgMutedBrush}"
                         Background="Transparent"
                         BorderThickness="0"
                         Padding="14,8"
                         IsReadOnly="True"
                         IsReadOnlyCaretVisible="True"
                         VerticalScrollBarVisibility="Auto"
                         HorizontalScrollBarVisibility="Auto"
                         TextWrapping="NoWrap"/>

                <Border Grid.Row="2"
                        Background="{StaticResource AccentBlueDimBrush}"
                        Padding="14,5">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBox Text="{Binding StatusMessage}"
                                 FontSize="12"
                                 FontWeight="SemiBold"
                                 Foreground="{StaticResource FgDefaultBrush}"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 Padding="0"
                                 IsReadOnly="True"
                                 IsReadOnlyCaretVisible="True"
                                 VerticalAlignment="Center"/>

                        <Button Grid.Column="1"
                                Command="{Binding CancelOperationCommand}"
                                Style="{StaticResource GhostButton}"
                                Foreground="{StaticResource FgDefaultBrush}"
                                Height="22"
                                Padding="10,0"
                                FontSize="11"
                                Margin="0,0,12,0"
                                Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}">
                            <TextBlock Text="取消操作"/>
                        </Button>

                        <StackPanel Grid.Column="2" Orientation="Horizontal">
                            <TextBlock Foreground="{StaticResource FgDefaultBrush}"
                                       FontSize="12"
                                       VerticalAlignment="Center"
                                       Margin="0,0,12,0">
                                <Run Text="{Binding MigrationCount, Mode=OneWay}"/>
                                <Run Text=" migrations"/>
                            </TextBlock>
                            <TextBlock Text="{Binding ActiveProfile.DisplayName}"
                                       FontWeight="SemiBold"
                                       FontSize="12"
                                       Foreground="{StaticResource FgDefaultBrush}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
        </Border>
    </Grid>
</UserControl>